@page
@model PLCARD.Pages.Corporates.IndexModel
@{
    ViewData["Title"] = "Corporate Dashboard";
}

<style>
    /* UI CORE THEME */
    .shadow-heavy {
        box-shadow: 0 20px 45px rgba(0, 0, 0, 0.15), 0 10px 20px rgba(0, 0, 0, 0.05) !important;
        border: none !important;
    }

    .stat-card {
        border-radius: 20px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        background: #fff;
        border: none;
    }

    .stat-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 25px 50px rgba(0, 0, 0, 0.18) !important;
    }

    .dashboard-title {
        background: linear-gradient(90deg, #1e1b4b, #3b82f6);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    /* TABLE STYLING */
    .table-container { border-radius: 22px; background: #fff; overflow: hidden; }
    
    .table thead th {
        background-color: #f8fafc;
        text-transform: uppercase;
        font-size: 0.72rem;
        letter-spacing: 1.2px;
        font-weight: 800;
        color: #475569;
        padding: 18px;
        border-bottom: 2px solid #f1f5f9;
    }

    .company-avatar {
        width: 44px; height: 44px; background: #eef2ff; color: #4338ca;
        display: flex; align-items: center; justify-content: center;
        font-weight: 700; border-radius: 12px; border: 1px solid #c7d2fe;
    }

    /* ALERT PULSATING ANIMATIONS */
    @@keyframes pulse-warning {
        0% { box-shadow: 0 0 0 0 rgba(245, 158, 11, 0.6); }
        70% { box-shadow: 0 0 0 10px rgba(245, 158, 11, 0); }
        100% { box-shadow: 0 0 0 0 rgba(245, 158, 11, 0); }
    }

    @@keyframes pulse-danger {
        0% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.6); }
        70% { box-shadow: 0 0 0 10px rgba(239, 68, 68, 0); }
        100% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0); }
    }

    .glow-soon {
        animation: pulse-warning 2s infinite;
        background: #fffbeb; color: #92400e; border: 1px solid #fcd34d;
    }

    .glow-expired {
        animation: pulse-danger 2s infinite;
        background: #fef2f2; color: #991b1b; border: 1px solid #fecaca;
    }

    .expiry-badge {
        font-size: 0.65rem; font-weight: 800; padding: 3px 10px;
        border-radius: 6px; display: inline-block; margin-top: 5px;
        text-transform: uppercase;
    }

    .badge-plan {
        background: #e0e7ff; color: #3730a3; padding: 5px 12px;
        border-radius: 8px; font-weight: 600; font-size: 0.75rem;
    }
</style>

<div class="container-fluid mt-4 px-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold dashboard-title mb-0">Corporate Directory</h1>
            <p class="text-muted">Agreement monitoring and company management dashboard</p>
        </div>
        <a asp-page="./Register" class="btn btn-primary btn-lg shadow-heavy rounded-pill px-4 fw-bold">
            <i class="fa fa-plus-circle me-2"></i> Register New Company
        </a>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-4">
            <div class="card stat-card shadow-heavy h-100 p-4 border-0">
                <div class="d-flex align-items-center">
                    <div class="bg-primary bg-opacity-10 p-3 rounded-circle me-3">
                        <i class="fa fa-building text-primary fs-3"></i>
                    </div>
                    <div>
                        <small class="text-muted fw-bold d-block">TOTAL COMPANIES</small>
                        <h2 class="fw-bold mb-0">@Model.TotalCompanies</h2>
                        <span class="small text-muted">Registered in System</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card shadow-heavy p-4 h-100 stat-card border-0">
                <form method="get" class="row g-3 align-items-end">
                    @Html.AntiForgeryToken()
                    <div class="col-md-4">
                        <label class="form-label small fw-bold text-muted">Created From</label>
                        <input type="date" asp-for="FromDate" class="form-control border-0 bg-light rounded-3" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-bold text-muted">Created To</label>
                        <input type="date" asp-for="ToDate" class="form-control border-0 bg-light rounded-3" />
                    </div>
                    <div class="col-md-4">
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-dark flex-fill fw-bold rounded-3">Filter</button>
                            <button type="submit" asp-page-handler="ExportExcel" formmethod="post" class="btn btn-outline-primary flex-fill fw-bold rounded-3">
                                <i class="fa fa-file-excel me-1"></i> Export
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="card shadow-heavy table-container border-0 mb-5">
        <div class="card-body p-0">
            <table id="companyTable" class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">Company Details</th>
                        <th>Plan & Type</th>
                        <th>Primary Contact</th>
                        <th>Agreement Status</th>
                        <th class="text-center pe-4">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Companies)
                    {
                        var firstLetter = !string.IsNullOrEmpty(item.VchCompanyName) ? item.VchCompanyName[0].ToString().ToUpper() : "C";
                        
                        // Expiry Calculations
                        bool hasDate = item.DtAgreementEnd.HasValue;
                        var diff = hasDate ? (item.DtAgreementEnd.Value.Date - DateTime.Today).TotalDays : 999;
                        bool isExpired = hasDate && diff < 0;
                        bool isSoon = hasDate && diff >= 0 && diff <= 7;

                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <div class="company-avatar me-3 shadow-sm">@firstLetter</div>
                                    <div>
                                        <div class="fw-bold text-dark">@item.VchCompanyName</div>
                                        <div class="small text-muted"><i class="fa fa-map-marker-alt me-1"></i> @item.VchCity</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="badge-plan mb-1 d-inline-block">@item.IntPlan?.VchPlanName</span>
                                <div>
                                    @if(item.BitIsCredit) { <small class="text-success fw-bold"><i class="fa fa-check-circle me-1"></i>Credit Enabled</small> }
                                    else { <small class="text-muted"><i class="fa fa-coins me-1"></i>Cash Billing</small> }
                                </div>
                            </td>
                            <td>
                                <div class="fw-bold text-dark">@item.VchContactPerson</div>
                                <div class="small text-muted"><i class="fa fa-phone me-1"></i> @item.VchContactNo</div>
                            </td>
                            <td>
                                @if (hasDate)
                                {
                                    <div class="fw-bold @(isExpired ? "text-danger" : (isSoon ? "text-warning" : "text-success"))">
                                        @item.DtAgreementEnd.Value.ToString("dd MMM yyyy")
                                    </div>
                                    @if (isExpired) {
                                        <span class="expiry-badge glow-expired"><i class="fa fa-times-circle me-1"></i>Contract Expired</span>
                                    } else if (isSoon) {
                                        <span class="expiry-badge glow-soon"><i class="fa fa-clock me-1"></i>Renew in @diff Days</span>
                                    } else {
                                        <span class="text-muted small">Agreement Active</span>
                                    }
                                }
                                else { <span class="text-muted small">No Agreement Date</span> }
                            </td>
                            <td class="text-center pe-4">
                                <a asp-page="./Register" asp-route-id="@item.IntCompanyId" 
                                   class="btn btn-primary btn-sm rounded-pill px-4 shadow-sm fw-bold">
                                    <i class="fa fa-edit me-1"></i> Edit
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#companyTable').DataTable({
                "pageLength": 10,
                "dom": '<"d-flex justify-content-between align-items-center p-3"lf>rt<"p-3 d-flex justify-content-between align-items-center"ip>',
                "language": { "search": "", "searchPlaceholder": "🔍 Search by name, plan or contact..." }
            });
            // Match global search box style
            $('.dataTables_filter input').addClass('form-control bg-light border-0 shadow-soft px-4 rounded-pill').css('width', '320px');
        });
    </script>
}