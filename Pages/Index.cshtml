@page
@model IndexModel
@{
    ViewData["Title"] = "PLCARD Analytics Dashboard";
}

<style>
    /* 1. Isolation to protect Layout Header */
    #dashboard-wrapper {
        --primary: #4361ee;
        --text-main: #2b3674;
        --text-muted: #a3aed0;
        background-color: #f4f7fe; 
        min-height: 100vh;
        padding: 30px 0;
        font-family: 'Inter', sans-serif;
    }

    /* 2. Deep "Stunning" Shadows for Cards */
    .kpi-card, .glass-card {
        background: #ffffff !important;
        border: none !important;
        border-radius: 20px !important;
        /* Multi-layered shadow: one for depth, one for soft glow */
        box-shadow: 0 20px 27px 0 rgba(0, 0, 0, 0.05), 0 5px 15px 0 rgba(0, 0, 0, 0.08) !important;
        transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .kpi-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 30px 60px -12px rgba(50, 50, 93, 0.25), 0 18px 36px -18px rgba(0, 0, 0, 0.3) !important;
    }

    /* 3. Search Bar */
    .verify-pill-container {
        background: #ffffff;
        border-radius: 50px;
        padding: 8px 8px 8px 24px;
        box-shadow: 0 10px 25px rgba(67, 97, 238, 0.12);
        display: flex;
        align-items: center;
        border: 2px solid transparent;
    }
    .verify-pill-container:focus-within { border-color: var(--primary); }
    .verify-pill-container input { border: none !important; outline: none !important; background: transparent; width: 100%; font-weight: 500; }

    /* 4. Icon Boxes */
    .kpi-icon-box {
        width: 58px;
        height: 58px;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        margin-right: 20px;
    }

    .bg-light-blue { background: #e9edf7; color: #4361ee; }
    .bg-light-purple { background: #f4f2ff; color: #7047ee; }
    .bg-light-green { background: #e6faf5; color: #05cd99; }
    .bg-light-cyan { background: #e0f7fa; color: #00bcd4; }
    .bg-light-orange { background: #fef5ee; color: #ff9920; }

    .kpi-label { font-size: 0.78rem; font-weight: 800; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; }
    .kpi-number { font-size: 1.8rem; font-weight: 800; color: var(--text-main); line-height: 1.2; }
</style>

<div id="dashboard-wrapper">
    <div class="container-fluid px-lg-5">
        
        <div class="row align-items-center mb-5">
            <div class="col-md-7">
                <h2 class="fw-bold text-dark mb-1" style="font-weight: 800;">Welcome back, admin!</h2>
                <p class="text-muted fw-500 mb-0">Indus Healthcare | Command Center Dashboard</p>
            </div>
            <div class="col-md-5">
                <form method="post" asp-page-handler="Search" class="verify-pill-container">
                    <input type="text" name="uhid" placeholder="Enter UHID to verify member..." required>
                    <button class="btn btn-primary rounded-pill px-4 fw-bold" type="submit">Verify</button>
                </form>
            </div>
        </div>

        <div class="row g-4 mb-5">
            @if (User.IsInRole("CorpUser") || User.IsInRole("Admin"))
            {
            <div class="col-xl">
                <div class="kpi-card p-4">
                    <div class="kpi-icon-box bg-light-blue"><i class="fa-solid fa-building"></i></div>
                    <div>
                        <div class="kpi-label">Companies</div>
                        <div class="kpi-number">@Model.TotalCompanies</div>
                    </div>
                </div>
            </div>
            <div class="col-xl">
                <div class="kpi-card p-4">
                    <div class="kpi-icon-box bg-light-purple"><i class="fa-solid fa-plus-circle"></i></div>
                    <div>
                        <div class="kpi-label">Reg. Today</div>
                        <div class="kpi-number">@Model.TodayRegistrations</div>
                    </div>
                </div>
            </div>
            }
            @if (User.IsInRole("CardUser") || User.IsInRole("Admin"))
            {
            <div class="col-xl">
                <div class="kpi-card p-4">
                    <div class="kpi-icon-box bg-light-green"><i class="fa-solid fa-id-card"></i></div>
                    <div>
                        <div class="kpi-label">Total Cards</div>
                        <div class="kpi-number">@Model.TotalCards</div>
                    </div>
                </div>
                </div>
            
               <div class="col-xl">
                    <div class="kpi-card p-4">
                        <div class="kpi-icon-box bg-light-cyan"><i class="fa-solid fa-calendar-day"></i></div>
                        <div>
                            <div class="kpi-label">Issued Today</div>
                            <div class="kpi-number">@Model.TodayIssuedCards</div>
                       </div>
                    </div>
                </div> 
            }
            <div class="col-xl">
                <div class="kpi-card p-4">
                    <div class="kpi-icon-box bg-light-orange"><i class="fa-solid fa-rotate"></i></div>
                    <div>
                        <div class="kpi-label">Pending Sync</div>
                        <div class="kpi-number">@Model.PendingSyncCount</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="row g-4 mb-5">
           @if (User.IsInRole("CorpUser") || User.IsInRole("Admin"))
            {
                <div class="col-lg-8">
                    <div class="card glass-card h-100">
                        <div class="card-body p-4">
                            <h5 class="fw-bold mb-4">Company Registration Trend (2026)</h5>
                            <div style="height: 350px;"><canvas id="registrationChart"></canvas></div>
                        </div>
                    </div>
                </div>
            }
            @if (User.IsInRole("CardUser") || User.IsInRole("Admin"))
            {
                <div class="col-lg-4">
                    <div class="card glass-card h-100">
                        <div class="card-body p-4">
                            <h5 class="fw-bold mb-4 text-center">Patient Card Type Mix</h5>
                            <div style="height: 350px;"><canvas id="cardTypeChart"></canvas></div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2"></script>
    
    <script>
        Chart.register(ChartDataLabels);

        // 1. Bar Chart - Only run if the element exists (CorpUser/Admin)
        const regCanvas = document.getElementById('registrationChart');
        if (regCanvas) {
            const regCtx = regCanvas.getContext('2d');
            new Chart(regCtx, {
                type: 'bar',
                data: {
                    labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'],
                    datasets: [{
                        data: @Html.Raw(Json.Serialize(Model.MonthlyRegistrationData)),
                        backgroundColor: '#4361ee',
                        borderRadius: 10,
                    }]
                },
                options: {
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        datalabels: {
                            anchor: 'end',
                            align: 'top',
                            color: '#4361ee',
                            font: { weight: 'bold', size: 12 }
                        }
                    },
                    scales: {
                        y: { display: false },
                        x: { grid: { display: false }, ticks: { color: '#a3aed0' } }
                    }
                }
            });
        }

        // 2. Doughnut Chart - Only run if the element exists (CardUser/Admin)
        const typeCanvas = document.getElementById('cardTypeChart');
        if (typeCanvas) {
            const typeCtx = typeCanvas.getContext('2d');
            new Chart(typeCtx, {
                type: 'doughnut',
                data: {
                    labels: ['Platinum', 'Gold', 'Silver'],
                    datasets: [{
                        data: @Html.Raw(Json.Serialize(Model.CardTypeDistribution)),
                        backgroundColor: ['#2b3674', '#ffda44', '#cbd5e0'],
                        borderWidth: 0,
                        spacing: 12
                    }]
                },
                options: {
                    cutout: '72%',
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'bottom', labels: { usePointStyle: true, padding: 25 } },
                        datalabels: {
                            color: (context) => context.dataset.backgroundColor[context.dataIndex] === '#ffda44' ? '#2b3674' : '#fff',
                            font: { weight: 'bold', size: 13 },
                            formatter: (val) => val > 0 ? val : ''
                        }
                    }
                }
            });
        }
    </script>
}