@page
@model PLCARD.Pages.Cards.IndexModel
@using PLCARD.Models
@using System.Linq
@{
    ViewData["Title"] = "Card Audit Dashboard";
    var records = Model.CardRecords ?? new List<TblCardRegistration>();

    var gold = records.Count(x => x.IntCard?.Vchcname?.Contains("GOLD", StringComparison.OrdinalIgnoreCase) == true);
    var silver = records.Count(x => x.IntCard?.Vchcname?.Contains("SILVER", StringComparison.OrdinalIgnoreCase) == true);
    var platinum = records.Count(x => x.IntCard?.Vchcname?.Contains("PLATINUM", StringComparison.OrdinalIgnoreCase) == true);
}

<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />

<style>
    body {
        background: linear-gradient(135deg, #f8fafc, #eef2ff);
    }

    .shadow-floating {
        box-shadow: 0 20px 60px -15px rgba(0,0,0,0.25);
    }

    .card-compact {
        border-radius: 18px;
        padding: 1.2rem;
        backdrop-filter: blur(10px);
        background: rgba(255,255,255,0.9);
        transition: 0.3s;
    }

    .card-compact:hover {
        transform: translateY(-4px);
        box-shadow: 0 25px 60px rgba(0,0,0,0.15);
    }

    .stat-number { font-size: 2rem; font-weight: 700; }

    .stat-icon-small {
        width: 45px;
        height: 45px;
        background: #ecfdf5;
        border-radius: 12px;
        display:flex;
        align-items:center;
        justify-content:center;
    }

    .stats-strip {
        display:flex;
        gap:6px;
        margin-top:10px;
    }

    .badge-mini {
        flex:1;
        font-size:0.65rem;
        padding:5px;
        border-radius:20px;
        text-align:center;
        font-weight:700;
    }

    .bg-gold { background:#fffbeb; color:#92400e; }
    .bg-silver { background:#f1f5f9; color:#334155; }
    .bg-platinum { background:#eff6ff; color:#1e40af; }

    .table-container {
        border-radius:15px;
        background:#fff;
    }

    .table tbody tr {
        transition:0.2s;
    }

    .table tbody tr:hover {
        background:#f1f5f9;
        transform:scale(1.002);
    }

    #cardTable { display:none; }
</style>

<div class="container-fluid mt-3 px-4 pb-5">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="fw-bold mb-0">Audit Dashboard</h2>
            <small class="text-muted">Indus Group | Card Management</small>
        </div>

        <a asp-page="./Issue" class="btn btn-success rounded-pill px-4 fw-bold shadow-sm">
            + New Registration
        </a>
    </div>

    <!-- TOP CARDS -->
    <div class="row g-3 mb-4">

        <div class="col-lg-4">
            <div class="card card-compact shadow-floating">
                <div class="d-flex justify-content-between">
                    <div>
                        <small class="text-muted fw-bold">TOTAL</small>
                        <div class="stat-number">@records.Count</div>
                    </div>
                    <div class="stat-icon-small">
                        <i class="fa fa-id-card"></i>
                    </div>
                </div>

                <div class="stats-strip">
                    <span class="badge-mini bg-gold">Gold: @gold</span>
                    <span class="badge-mini bg-silver">Silver: @silver</span>
                    <span class="badge-mini bg-platinum">Plat: @platinum</span>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card card-compact shadow-floating">
                <form method="get" class="row g-2">
                    <div class="col-md-4">
                        <input type="date" asp-for="FromDate" class="form-control form-control-sm bg-light border-0" />
                    </div>
                    <div class="col-md-4">
                        <input type="date" asp-for="ToDate" class="form-control form-control-sm bg-light border-0" />
                    </div>
                    <div class="col-md-4 d-flex gap-2">
                        <button class="btn btn-dark btn-sm w-100">Filter</button>
                        <button asp-page-handler="ExportExcel" formmethod="post" class="btn btn-outline-primary btn-sm w-100">Export</button>
                    </div>
                </form>
            </div>
        </div>

    </div>

    <!-- LOADER -->
    <div id="loader">
        @for (int i = 0; i < 6; i++)
        {
            <div class="placeholder-glow mb-2">
                <span class="placeholder col-12"></span>
            </div>
        }
    </div>

    <!-- TABLE -->
    <div id="tableWrapper" class="card shadow-floating table-container p-3">

        <div class="table-responsive">
            <table id="cardTable" class="table table-hover align-middle w-100">
                <thead>
                    <tr>
                        <th>ID / DATE</th>
                        <th>PATIENT</th>
                        <th>CARD</th>
                        <th>CONTACT</th>
                        <th class="text-center">ACTION</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in records)
                    {
                        var plan = item.IntCard?.Vchcname?.ToUpper() ?? "GENERAL";

                        <tr>
                            <td>
                                <b>#@item.IntRegId</b><br />
                                <small>@item.Dtcreated?.ToString("dd-MMM-yyyy")</small>
                            </td>

                            <td>
                                <b>@item.Vchname</b><br />
                                <small>@item.VchUhidno</small>
                            </td>

                            <td>
                                <span class="badge-mini @(plan.Contains("GOLD") ? "bg-gold" : plan.Contains("SILVER") ? "bg-silver" : "bg-platinum")">
                                    @plan
                                </span>
                                <div class="text-success fw-bold">₹@item.IntCharges</div>
                            </td>

                            <td>
                                <b>@item.Vchcontactno</b><br />
                                <small>@item.Vchcity</small>
                            </td>

                            <td class="text-center">
                                <a asp-page="./Issue" asp-route-id="@item.IntRegId"
                                   class="btn btn-primary btn-sm rounded-pill">
                                    Edit
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>
</div>

@section Scripts {

<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

<script>
    $(document).ready(function () {

        let table = $('#cardTable').DataTable({
            order: [[0, "desc"]],
            pageLength: 10,
            deferRender: true,
            stateSave: true,
            processing: true,
            dom: '<"d-flex justify-content-between mb-2"lf>rt<"d-flex justify-content-between mt-2"ip>',
            language: {
                search: "",
                searchPlaceholder: "Search...",
            }
        });

        // Smooth load
        setTimeout(() => {
            $('#loader').hide();
            $('#cardTable').fadeIn(200);
        }, 300);

        $('.dataTables_filter input')
            .addClass('form-control form-control-sm bg-light border-0 rounded-pill')
            .css('width', '220px');

    });
</script>

}