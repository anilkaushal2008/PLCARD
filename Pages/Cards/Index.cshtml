@page
@model PLCARD.Pages.Cards.IndexModel
@using PLCARD.Models
@{
    ViewData["Title"] = "Card Audit Dashboard";
    var records = Model.CardRecords ?? new List<TblCardRegistration>();
    
    // Stats calculation
    var gold = records.Count(x => x.IntCard?.Vchcname?.Contains("GOLD", StringComparison.OrdinalIgnoreCase) == true);
    var silver = records.Count(x => x.IntCard?.Vchcname?.Contains("SILVER", StringComparison.OrdinalIgnoreCase) == true);
    var platinum = records.Count(x => x.IntCard?.Vchcname?.Contains("Platinum", StringComparison.OrdinalIgnoreCase) == true);
}

<style>
    /* DEEPER SHADOWS */
    .shadow-heavy {
        box-shadow: 0 20px 45px rgba(0, 0, 0, 0.15), 0 10px 20px rgba(0, 0, 0, 0.05) !important;
        border: none !important;
    }

    .shadow-soft {
        box-shadow: 0 12px 30px rgba(0, 0, 0, 0.08) !important;
        border: 1px solid rgba(0,0,0,0.02) !important;
    }

    .stat-card {
        border-radius: 18px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        background: #fff;
    }

    .stat-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 25px 50px rgba(0, 0, 0, 0.2) !important;
    }

    .table-container { border-radius: 20px; background: #fff; }
    
    .table thead th {
        background-color: #f1f5f9;
        text-transform: uppercase;
        font-size: 0.7rem;
        letter-spacing: 1.2px;
        font-weight: 800;
        color: #334155;
        padding: 15px;
    }

    .badge-modern { padding: 6px 12px; border-radius: 8px; font-weight: 600; border: 1px solid transparent; }
    .bg-gold { background: #fffbeb; color: #92400e; border-color: #fde68a; }
    .bg-silver { background: #f8fafc; color: #475569; border-color: #e2e8f0; }
    .bg-corporate { background: #eff6ff; color: #1e40af; border-color: #bfdbfe; }

    .dashboard-title {
        background: linear-gradient(90deg, #0f172a, #2563eb);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }
</style>

<div class="container-fluid mt-4 px-4">

    <div class="row align-items-center mb-4">
        <div class="col-md-6">
            <h1 class="fw-bold dashboard-title">Audit Dashboard</h1>
            <p class="text-muted">Overview of Card Registrations & Revenue</p>
        </div>
        <div class="col-md-6 text-md-end">
            <a asp-page="./Issue" class="btn btn-success btn-lg shadow-heavy rounded-pill px-4 fw-bold">
                <i class="fa fa-plus-circle me-2"></i> New Registration
            </a>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-4">
            <div class="card stat-card shadow-heavy h-100 p-4">
                <div class="d-flex align-items-center">
                    <div class="bg-primary bg-opacity-10 p-3 rounded-circle me-3">
                        <i class="fa fa-id-card text-primary fs-3"></i>
                    </div>
                    <div>
                        <small class="text-muted fw-bold d-block">TOTAL ISSUED</small>
                        <h2 class="fw-bold mb-0">@records.Count</h2>
                        <div class="small mt-1">
                            <span class="badge bg-gold">Gold: @gold</span>
                            <span class="badge bg-silver">Silver: @silver</span>
                            <span class="badge bg-corporate">Platinum: @platinum</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card shadow-heavy p-4 h-100 stat-card">
                <form method="get" id="filterForm" class="row g-3 align-items-end">
                    @Html.AntiForgeryToken() @* CRITICAL FOR EXPORT *@
                    <div class="col-md-4">
                        <label class="form-label small fw-bold text-muted">From Date</label>
                        <input type="date" asp-for="FromDate" class="form-control border-0 bg-light rounded-3" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label small fw-bold text-muted">To Date</label>
                        <input type="date" asp-for="ToDate" class="form-control border-0 bg-light rounded-3" />
                    </div>

                    <div class="col-md-4">
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-dark flex-fill fw-bold rounded-3">
                                <i class="fa fa-filter me-1"></i> Apply
                            </button>

                            <button type="submit" 
                                    asp-page-handler="ExportExcel" 
                                    formmethod="post" 
                                    class="btn btn-outline-primary flex-fill fw-bold rounded-3 shadow-sm">
                                <i class="fa fa-file-excel me-1"></i> Export
                            </button>
                        </div>
                    </div>
                </form>                
            </div>
        </div>
    </div>

    <div class="card shadow-heavy table-container border-0 overflow-hidden">
        <div class="card-body p-0">
            <table id="cardTable" class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">Date</th>
                        <th>UHID / Patient</th>
                        <th>Card Details</th>
                        <th>Contact</th>
                        <th class="text-center pe-4">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in records)
                    {
                        var planType = item.IntCard?.Vchcname?.ToUpper() ?? item.VchCardType?.ToUpper() ?? "UNKNOWN";
                        string pClass = planType switch {
                            var p when p.Contains("GOLD") => "bg-gold",
                            var p when p.Contains("SILVER") => "bg-silver",
                            _ => "bg-corporate"
                        };

                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold text-dark">@item.Dtcreated?.ToString("dd MMM yyyy")</div>
                                <small class="text-muted">ID: #@item.IntRegId</small>
                            </td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="bg-light text-primary rounded-circle d-flex align-items-center justify-content-center me-3 fw-bold" style="width:38px;height:38px; border: 1px solid #e2e8f0;">
                                        @(!string.IsNullOrEmpty(item.Vchname) ? item.Vchname[0].ToString().ToUpper() : "P")
                                    </div>
                                    <div>
                                        <div class="fw-bold text-dark">@item.Vchname</div>
                                        <div class="text-muted small">UHID: @item.VchUhidno</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="badge-modern @pClass mb-1 d-inline-block">
                                    <i class="fa fa-id-card me-1 small"></i> @planType
                                </span>
                                <div class="small fw-bold text-success">₹@item.IntCharges</div>
                            </td>
                            <td>
                                <div class="small fw-bold"><i class="fa fa-phone-alt me-1 text-muted"></i> @item.Vchcontactno</div>
                                <div class="small text-muted text-truncate" style="max-width: 150px;">@item.Vchcity</div>
                            </td>
                            <td class="text-center pe-4">
                                <a asp-page="./Issue" asp-route-id="@item.IntRegId" 
                                   class="btn btn-primary btn-sm rounded-pill px-3 shadow-sm fw-bold">
                                    <i class="fa fa-edit me-1"></i> Edit
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            
        </div>
    </div>
    <br />
    <br />
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            var table = $('#cardTable').DataTable({
                order: [[0, "desc"]],
                pageLength: 10,
                dom: '<"d-flex justify-content-between align-items-center p-3"lf>rt<"p-3 d-flex justify-content-between align-items-center"ip>',
                language: {
                    search: "",
                    searchPlaceholder: "🔍 Search patient, UHID or Card..."
                }
            });

            $('.dataTables_filter input').addClass('form-control bg-light border-0 shadow-soft px-4 rounded-pill').css('width', '300px');
        });
    </script>
}