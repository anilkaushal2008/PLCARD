@page "{id:int?}"
@model PLCARD.Pages.Cards.IssueModel
@{
    ViewData["Title"] = Model.Registration.IntRegId == 0 ? "Register Card" : "Update Card";
}

<style>
    /* Layout & Footer Fix */
    .main-wrapper { 
        padding-bottom: 120px; /* Ensures buttons are visible above footer */
        margin-bottom: 60px; 
    }
    
    /* Modern Styling with Enhanced Shadow */
    .card-modern { 
        border-radius: 18px; 
        background: #fff; 
        box-shadow: 0 15px 50px rgba(0, 0, 0, 0.12); /* Deeper, soft shadow */
        border: none; 
    }

    .section-title { font-weight: 700; font-size: 0.9rem; color: #157347; border-left: 4px solid #198754; padding-left: 12px; margin-bottom: 20px; text-transform: uppercase; letter-spacing: 0.5px; }
    .form-label { font-size: 0.75rem; font-weight: 700; color: #4b5563; margin-bottom: 4px; display: block; }
    
    /* Inputs */
    .form-control, .form-select { border-radius: 10px; border: 1px solid #d1d5db; padding: 0.6rem 0.8rem; transition: 0.2s; font-size: 0.9rem; }
    .form-control:focus { border-color: #198754; box-shadow: 0 0 0 3px rgba(25,135,84,0.15); }
    .required-star { color: #dc3545; margin-left: 2px; }
    
    /* Components */
    .cost-box { background: linear-gradient(135deg, #f0fdf4, #dcfce7); border-radius: 12px; padding: 10px 18px; border: 1px solid #bbf7d0; text-align: right; min-width: 140px; }
    .btn-modern { border-radius: 10px; font-weight: 600; padding: 12px 30px; transition: all 0.2s; }
    .btn-modern:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(0,0,0,0.15); }
    
    /* Preview Modal Table */
    #previewTable thead { position: sticky; top: 0; z-index: 10; }
    #previewTable input { font-size: 11px; padding: 2px 5px; border-radius: 4px; }
</style>

<div class="container-fluid mt-4 px-4 main-wrapper">
    
    @* Header Section: Title + Cost + Navigation *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="d-flex align-items-center gap-3">
            <a asp-page="./Index" class="btn btn-light shadow-sm rounded-circle p-2" style="width:40px; height:40px;">
                <i class="fa fa-arrow-left text-secondary"></i>
            </a>
            <div>
                <h3 class="fw-bold text-dark mb-0">
                    <i class="fa @(Model.Registration.IntRegId == 0 ? "fa-id-card text-success" : "fa-user-pen text-warning") me-2"></i>
                    @(Model.Registration.IntRegId == 0 ? "Card Registration" : "Update Registration")
                </h3>
                <p class="text-muted small mb-0">Indus Healthcare Group | Central Sync System</p>
            </div>
        </div>

        <div class="d-flex align-items-center gap-3">
            @* Cost Display Box *@
            <div class="cost-box shadow-sm border-0">
                <small class="text-success fw-bold" style="font-size: 0.65rem; text-transform: uppercase;">Applicable Charges</small><br />
                <span class="fw-bold fs-4 text-success">₹<span id="displayCost">@(Model.CurrentCost ?? 0)</span></span>
            </div>
            @* List View Link *@
            <a asp-page="./Index" class="btn btn-success btn-modern shadow border-0 d-flex align-items-center" style="height: 52px;">
                <i class="fa fa-list-ul me-2"></i> View All Cards
            </a>
        </div>
    </div>

    @* Bulk Upload Card *@
    <div class="card card-modern border-0 mb-4" style="background: #f8fafc; border: 1px dashed #cbd5e1 !important;">
        <div class="card-body p-3">
            <div class="row align-items-center">
                <div class="col-md-5">
                    <h6 class="fw-bold mb-1"><i class="fa fa-file-excel text-success me-2"></i>Bulk Import Utility</h6>
                    <small class="text-muted">Register multiple patients at once using Excel.</small>
                </div>
                <div class="col-md-7 text-end">
                    <form id="bulkUploadForm" method="post" enctype="multipart/form-data" class="d-flex gap-2 justify-content-end align-items-center">
                        @Html.AntiForgeryToken()
                        <a asp-page-handler="DownloadTemplate" class="text-success small fw-bold text-decoration-none me-3">
                            <i class="fa fa-download me-1"></i> Download Template
                        </a>
                        <input type="file" name="ExcelFile" accept=".xlsx" class="form-control form-control-sm w-auto" required />
                        <button type="submit" class="btn btn-success btn-sm px-4 rounded-pill shadow-sm">
                            <i class="fa fa-eye me-1"></i> Preview
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    @* Main Registration Form *@
    <form method="post" id="mainRegForm">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Registration.IntRegId" />
        
        <div class="card card-modern p-4">
            
            @* Row 1: Card Logic *@
            <div class="section-title">Step 1: Card & Billing</div>
            <div class="row g-4 mb-5">
                <div class="col-md-3">
                    <label class="form-label">Card Category <span class="required-star">*</span></label>
                    <select asp-for="Registration.IntCardId" id="cardSelect" asp-items="Model.CardTypeList" class="form-select" required>
                        <option value="">-- Choose Category --</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">HMS Receipt No <span class="required-star">*</span></label>
                    <input asp-for="Registration.VchHmsRcpt" class="form-control" placeholder="Enter Receipt No" required />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Amount Charged (₹) <span class="required-star">*</span></label>
                    <input asp-for="Registration.IntCharges" type="number" class="form-control" required />
                </div>
                <div class="col-md-3">
                    <label class="form-label">UHID Number</label>
                    <input asp-for="Registration.VchUhidno" class="form-control" placeholder="Existing UHID if any" />
                </div>
            </div>

            @* Row 2: Personal Info *@
            <div class="section-title">Step 2: Patient Details</div>
            <div class="row g-4 mb-5">
                <div class="col-md-3">
                    <label class="form-label">Patient Name <span class="required-star">*</span></label>
                    <input asp-for="Registration.Vchname" class="form-control" required />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Father/Spouse Name <span class="required-star">*</span></label>
                    <input asp-for="Registration.VchspouseName" class="form-control" required />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Gender <span class="required-star">*</span></label>
                    <select asp-for="Registration.Vchsex" class="form-select" required>
                        <option value="">Select</option>
                        <option>Male</option>
                        <option>Female</option>
                        <option>Other</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Date of Birth <span class="required-star">*</span></label>
                    <input asp-for="Registration.DtDob" id="dobInput" type="date" class="form-control" required />
                </div>
            </div>

            @* Row 3: Contacts *@
            <div class="section-title">Step 3: Contact & Referral</div>
            <div class="row g-4 mb-5">
                <div class="col-md-2">
                    <label class="form-label">Calculated Age</label>
                    <input asp-for="Registration.Intage" id="ageInput" type="number" class="form-control bg-light" readonly />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Mobile Number <span class="required-star">*</span></label>
                    <input asp-for="Registration.Vchcontactno" class="form-control" placeholder="10 Digits" required />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Email Address</label>
                    <input asp-for="Registration.Vchemail" type="email" class="form-control" placeholder="patient@gmail.com" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Referred By / Staff</label>
                    <input asp-for="Registration.VchCardRefBy" class="form-control" />
                </div>
            </div>

            @* Row 4: Address *@
            <div class="section-title">Step 4: Residential Address</div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">House/Street Address <span class="required-star">*</span></label>
                    <input asp-for="Registration.VchAddress" class="form-control" required />
                </div>
                <div class="col-md-2">
                    <label class="form-label">City <span class="required-star">*</span></label>
                    <input asp-for="Registration.Vchcity" class="form-control" required />
                </div>
                <div class="col-md-2">
                    <label class="form-label">State</label>
                    <input asp-for="Registration.VchsState" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Pincode</label>
                    <input asp-for="Registration.Vchpincode" class="form-control" />
                </div>
            </div>

            @* Final Actions *@
            <div class="mt-5 pt-4 border-top d-flex gap-3">
                <button type="submit" class="btn btn-success btn-modern shadow px-5">
                    <i class="fa fa-cloud-arrow-up me-2"></i> 
                    @(Model.Registration.IntRegId == 0 ? "Register & Sync" : "Save Changes")
                </button>
                <a asp-page="./Index" class="btn btn-outline-secondary btn-modern px-4">
                    <i class="fa fa-times me-2"></i> Cancel
                </a>
            </div>
        </div>
    </form>
</div>

@* Bulk Preview Modal *@
<div class="modal fade" id="previewModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-fullscreen p-4">
        <div class="modal-content card-modern overflow-hidden">
            <div class="modal-header bg-success text-white py-3">
                <h5 class="modal-title fw-bold"><i class="fa fa-table-list me-2"></i> Excel Preview: Review Data Before Sync</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body bg-light p-0">
                <div class="table-responsive" style="max-height: calc(100vh - 200px);">
                    <table class="table table-hover table-bordered bg-white mb-0" id="previewTable">
                        <thead class="table-dark">
                            <tr style="font-size: 11px;">
                                <th>Name</th><th>Mobile</th><th>DOB</th><th>Sex</th><th>Age</th>
                                <th>Spouse</th><th>Email</th><th>Address</th><th>City</th><th>State</th>
                                <th>Pin</th><th>UHID</th><th>Receipt</th><th>Amount</th><th>CardType</th>
                                <th>RefBy</th><th class="text-center">Status</th>
                            </tr>
                        </thead>
                        <tbody>@* Loaded via AJAX *@</tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer bg-white shadow-lg">
                <div class="me-auto">
                    <span class="text-muted small">TOTAL REVENUE:</span>
                    <span class="h5 fw-bold text-success ms-1">₹<span id="bulkTotal">0</span></span>
                </div>
                <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="btnSaveBulk" class="btn btn-success btn-modern px-5">Confirm & Register All</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(function () {
            // Anti-Forgery Setup for AJAX
            const token = $('input[name="__RequestVerificationToken"]').val();

            // 1. Cost Fetcher
            $('#cardSelect').change(function () {
                const id = $(this).val();
                if (id) {
                    $('#displayCost').html('<i class="fa fa-spinner fa-spin"></i>');
                    $.getJSON(`?handler=CardCost&id=${id}`, data => $('#displayCost').text(data.cost));
                }
            });

            // 2. Age from DOB
            $('#dobInput').on('change', function () {
                const dob = new Date($(this).val());
                const today = new Date();
                let age = today.getFullYear() - dob.getFullYear();
                if (today.getMonth() < dob.getMonth() || (today.getMonth() === dob.getMonth() && today.getDate() < dob.getDate())) age--;
                $('#ageInput').val(age >= 0 ? age : 0);
            });

            // 3. Excel Preview
            $('#bulkUploadForm').submit(function (e) {
                e.preventDefault();
                const $btn = $(this).find('button[type="submit"]');
                const originalHtml = $btn.html();
                
                $btn.prop('disabled', true).html('<i class="fa fa-spinner fa-spin"></i>');

                $.ajax({
                    url: '?handler=PreviewExcel',
                    type: 'POST',
                    data: new FormData(this),
                    processData: false, contentType: false,
                    success: function (res) {
                        if (res.error) { alert(res.error); return; }
                        
                        let html = '';
                        res.preview.forEach(i => {
                            const rowErr = i.isValid ? "" : "table-danger";
                            html += `<tr class="${rowErr}">
                                <td><input type="text" class="form-control val-name" value="${i.name || ''}"></td>
                                <td><input type="text" class="form-control val-mobile" value="${i.mobile || ''}"></td>
                                <td><input type="text" class="form-control val-dob" value="${i.dob || ''}"></td>
                                <td><input type="text" class="form-control val-sex" value="${i.gender || ''}"></td>
                                <td><input type="number" class="form-control val-age" value="${i.age || 0}"></td>
                                <td><input type="text" class="form-control val-spouse" value="${i.spouse || ''}"></td>
                                <td><input type="text" class="form-control val-email" value="${i.email || ''}"></td>
                                <td><input type="text" class="form-control val-address" value="${i.address || ''}"></td>
                                <td><input type="text" class="form-control val-city" value="${i.city || ''}"></td>
                                <td><input type="text" class="form-control val-state" value="${i.state || ''}"></td>
                                <td><input type="text" class="form-control val-pin" value="${i.pincode || ''}"></td>
                                <td><input type="text" class="form-control val-uhid" value="${i.uhid || ''}"></td>
                                <td><input type="text" class="form-control val-rcpt" value="${i.receipt || ''}"></td>
                                <td><input type="number" class="form-control val-amt" value="${i.amount || 0}"></td>
                                <td><input type="text" class="form-control val-card" value="${i.cardName || ''}"></td>
                                <td><input type="text" class="form-control val-refby" value="${i.refBy || ''}"></td>
                                <td class="text-center">${i.isValid ? '<i class="fa fa-circle-check text-success"></i>' : '<i class="fa fa-triangle-exclamation text-danger" title="'+i.error+'"></i>'}</td>
                            </tr>`;
                        });
                        $('#previewTable tbody').html(html);
                        $('#bulkTotal').text(res.totalAmount);
                        $('#previewModal').modal('show');
                    },
                    complete: () => $btn.prop('disabled', false).html(originalHtml)
                });
            });

            // 4. Final Save
            $('#btnSaveBulk').click(function () {
                const list = [];
                $('#previewTable tbody tr').each(function () {
                    list.push({
                        Vchname: $(this).find('.val-name').val(),
                        Vchcontactno: $(this).find('.val-mobile').val(),
                        DtDob: $(this).find('.val-dob').val(),
                        Vchsex: $(this).find('.val-sex').val(),
                        Intage: parseInt($(this).find('.val-age').val()),
                        VchspouseName: $(this).find('.val-spouse').val(),
                        Vchemail: $(this).find('.val-email').val(),
                        VchAddress: $(this).find('.val-address').val(),
                        Vchcity: $(this).find('.val-city').val(),
                        VchsState: $(this).find('.val-state').val(),
                        Vchpincode: $(this).find('.val-pin').val(),
                        VchUhidno: $(this).find('.val-uhid').val(),
                        VchHmsRcpt: $(this).find('.val-rcpt').val(),
                        IntCharges: parseInt($(this).find('.val-amt').val()),
                        VchCardType: $(this).find('.val-card').val(),
                        VchCardRefBy: $(this).find('.val-refby').val()
                    });
                });

                const $saveBtn = $(this);
                $saveBtn.prop('disabled', true).html('<i class="fa fa-spinner fa-spin me-2"></i> Registering...');

                $.ajax({
                    url: '?handler=UploadEdited',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(list),
                    headers: { "RequestVerificationToken": token },
                    success: function (res) {
                        alert(`Success! ${res.success} cards registered and added to sync queue.`);
                        location.href = './Index';
                    },
                    error: (err) => {
                        alert("Error saving data. Check network connection.");
                        $saveBtn.prop('disabled', false).text("Confirm & Register All");
                    }
                });
            });
        });
    </script>
}