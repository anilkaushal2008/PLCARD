@page "{id:int?}"
@model PLCARD.Pages.Cards.IssueModel
@{
    ViewData["Title"] = Model.Registration.IntRegId == 0 ? "Register Card" : "Update Card";
}

<style>
    .card-modern { border-radius: 18px; background: #fff; box-shadow: 0 10px 30px rgba(0,0,0,0.05); }
    .section-title { font-weight: 700; font-size: 0.95rem; color: #198754; border-left: 4px solid #198754; padding-left: 10px; margin-bottom: 15px; }
    .form-label { font-size: 0.78rem; font-weight: 600; color: #6b7280; margin-bottom: 3px; }
    .form-control, .form-select { border-radius: 10px; border: 1px solid #e5e7eb; transition: 0.2s; }
    .form-control:focus, .form-select:focus { border-color: #198754; box-shadow: 0 0 0 2px rgba(25,135,84,0.1); }
    .required-star { color: red; }
    .cost-box { background: linear-gradient(135deg, #ecfdf5, #d1fae5); border-radius: 12px; padding: 10px 15px; }
    .btn-modern { border-radius: 10px; font-weight: 600; }
    #previewTable input { min-width: 100px; font-size: 12px; }
</style>

<div class="container-fluid mt-4 px-4">
    
    <div class="d-flex justify-content-between align-items-start mb-3">
        <div class="d-flex align-items-center gap-3">
            <a asp-page="./Index" class="btn btn-outline-secondary btn-sm rounded-pill">
                <i class="fa fa-arrow-left"></i>
            </a>
            <div>
                <h4 class="fw-bold text-success mb-0">
                    <i class="fa @(Model.Registration.IntRegId == 0 ? "fa-plus-circle" : "fa-edit") me-2"></i>
                    @(Model.Registration.IntRegId == 0 ? "New Card Registration" : "Edit Card")
                </h4>
                <small class="text-muted">Enter card details below or use bulk upload</small>
            </div>
        </div>

        <div class="d-flex align-items-center gap-2">
            <a asp-page="./Index" class="btn btn-success btn-sm px-3 shadow-sm border-0" style="border-radius: 10px; height: 45px; display: flex; align-items: center;">
                <i class="fa fa-list-ul me-2"></i> View Card List
            </a>
            
            <div class="cost-box shadow-sm">
                <small class="text-muted" style="font-size: 0.7rem;">CARD COST</small><br />
                <span class="fw-bold fs-5 text-success">
                    ₹<span id="displayCost">@(Model.CurrentCost ?? 0)</span>
                </span>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-3" style="border-radius:12px;">
        <div class="d-flex justify-content-between align-items-center p-3 flex-wrap gap-2">
            <div>
                <h6 class="fw-bold mb-1"><i class="fa fa-file-excel text-success me-2"></i>Bulk Upload</h6>
                <small class="text-muted">Use the template to upload multiple records at once</small>
            </div>
            <div class="d-flex gap-2">
                <a asp-page-handler="DownloadTemplate" class="btn btn-outline-success btn-sm">
                    <i class="fa fa-download me-1"></i> Download Template
                </a>
                <form id="bulkUploadForm" method="post" enctype="multipart/form-data" class="d-flex gap-2 align-items-center">
                    @Html.AntiForgeryToken()
                    <input type="file" name="ExcelFile" accept=".xlsx" class="form-control form-control-sm" style="max-width:200px;" required />
                    <button type="submit" class="btn btn-success btn-sm px-3">
                        <i class="fa fa-upload me-1"></i> Preview & Upload
                    </button>
                </form>
            </div>
        </div>
    </div>

    <form method="post">
        <input type="hidden" asp-for="Registration.IntRegId" />
        <div class="card card-modern border-0 p-4">
            
            <div class="section-title">Card & Payment</div>
            <div class="row g-3 mb-4">
                <div class="col-md-3">
                    <label class="form-label">Card Type <span class="required-star">*</span></label>
                    <select asp-for="Registration.IntCardId" id="cardSelect" asp-items="Model.CardTypeList" class="form-select" required>
                        <option value="">Select Type</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Receipt No <span class="required-star">*</span></label>
                    <input asp-for="Registration.VchHmsRcpt" class="form-control" required />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Amount (₹) <span class="required-star">*</span></label>
                    <input asp-for="Registration.IntCharges" type="number" class="form-control" required />
                </div>
                <div class="col-md-3">
                    <label class="form-label">UHID</label>
                    <input asp-for="Registration.VchUhidno" class="form-control" />
                </div>
            </div>

            <div class="section-title">Personal Details</div>
            <div class="row g-3 mb-4">
                <div class="col-md-3">
                    <label class="form-label">Name <span class="required-star">*</span></label>
                    <input asp-for="Registration.Vchname" class="form-control" required />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Father/Spouse <span class="required-star">*</span></label>
                    <input asp-for="Registration.VchspouseName" class="form-control" required />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Gender <span class="required-star">*</span></label>
                    <select asp-for="Registration.Vchsex" class="form-select" required>
                        <option value="">Select</option>
                        <option>Male</option>
                        <option>Female</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">DOB <span class="required-star">*</span></label>
                    <input asp-for="Registration.DtDob" id="dobInput" type="date" class="form-control" required />
                </div>
            </div>

            <div class="section-title">Contact & Referred By</div>
            <div class="row g-3 mb-4">
                <div class="col-md-2">
                    <label class="form-label">Age</label>
                    <input asp-for="Registration.Intage" id="ageInput" type="number" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Mobile <span class="required-star">*</span></label>
                    <input asp-for="Registration.Vchcontactno" class="form-control" required />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Email</label>
                    <input asp-for="Registration.Vchemail" type="email" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Referred By</label>
                    <input asp-for="Registration.VchCardRefBy" class="form-control" placeholder="Doctor or Staff name" />
                </div>
            </div>

            <div class="section-title">Address</div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Address <span class="required-star">*</span></label>
                    <input asp-for="Registration.VchAddress" class="form-control" required />
                </div>
                <div class="col-md-2">
                    <label class="form-label">City <span class="required-star">*</span></label>
                    <input asp-for="Registration.Vchcity" class="form-control" required />
                </div>
                <div class="col-md-2">
                    <label class="form-label">State</label>
                    <input asp-for="Registration.VchsState" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Pincode</label>
                    <input asp-for="Registration.Vchpincode" class="form-control" />
                </div>
            </div>

            <div class="mt-5 d-flex gap-3 border-top pt-4">
                <button type="submit" class="btn btn-success btn-modern px-5">
                    <i class="fa fa-save me-2"></i> @(Model.Registration.IntRegId == 0 ? "Register Card" : "Update Details")
                </button>
                
                <a asp-page="./Index" class="btn btn-outline-secondary btn-modern px-4">
                    <i class="fa fa-list me-2"></i> Back to List
                </a>
            </div>
        </div>
    </form>
</div>

<div class="modal fade" id="previewModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-fullscreen p-4">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title"><i class="fa fa-table me-2"></i> Review Bulk Data</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body bg-light">
                <div class="table-responsive bg-white p-2 rounded shadow-sm">
                    <table class="table table-sm table-bordered align-middle" id="previewTable">
                        <thead class="table-dark">
                            <tr style="font-size:11px;">
                                <th>Name</th><th>Mobile</th><th>DOB</th><th>Sex</th><th>Age</th>
                                <th>Spouse</th><th>Email</th><th>Address</th><th>City</th><th>State</th>
                                <th>Pin</th><th>UHID</th><th>Receipt</th><th>Amount</th><th>CardType</th>
                                <th>RefBy</th><th>Status</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer bg-white">
                <span class="me-auto fw-bold text-success">Total Amount: ₹<span id="bulkTotal">0</span></span>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="btnSaveBulk" class="btn btn-success px-4">Confirm & Upload All</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(function () {
            // Card Cost Fetcher
            $('#cardSelect').change(function () {
                var id = $(this).val();
                if (id) {
                    $.getJSON('?handler=CardCost&id=' + id, data => $('#displayCost').text(data.cost));
                }
            });

            // Auto-calculate Age from DOB
            $('#dobInput').change(function () {
                var dob = new Date($(this).val());
                var today = new Date();
                var age = today.getFullYear() - dob.getFullYear();
                if (today.getMonth() < dob.getMonth() || (today.getMonth() === dob.getMonth() && today.getDate() < dob.getDate())) age--;
                $('#ageInput').val(age >= 0 ? age : 0);
            });

            // AJAX Preview Excel
            $('#bulkUploadForm').submit(function (e) {
                e.preventDefault();
                var formData = new FormData(this);
                $.ajax({
                    url: '?handler=PreviewExcel',
                    type: 'POST',
                    data: formData,
                    processData: false, contentType: false,
                    success: function (res) {
                        if (res.error) { alert(res.error); return; }
                        var html = '';
                        res.preview.forEach(i => {
                            html += `<tr class="${i.isValid ? '' : 'table-danger'}">
                                <td><input type="text" class="form-control form-control-sm val-name" value="${i.name}"></td>
                                <td><input type="text" class="form-control form-control-sm val-mobile" value="${i.mobile}"></td>
                                <td><input type="text" class="form-control form-control-sm val-dob" value="${i.dob}"></td>
                                <td><input type="text" class="form-control form-control-sm val-sex" value="${i.gender}"></td>
                                <td><input type="number" class="form-control form-control-sm val-age" value="${i.age}"></td>
                                <td><input type="text" class="form-control form-control-sm val-spouse" value="${i.spouse}"></td>
                                <td><input type="text" class="form-control form-control-sm val-email" value="${i.email}"></td>
                                <td><input type="text" class="form-control form-control-sm val-address" value="${i.address}"></td>
                                <td><input type="text" class="form-control form-control-sm val-city" value="${i.city}"></td>
                                <td><input type="text" class="form-control form-control-sm val-state" value="${i.state}"></td>
                                <td><input type="text" class="form-control form-control-sm val-pin" value="${i.pincode}"></td>
                                <td><input type="text" class="form-control form-control-sm val-uhid" value="${i.uhid}"></td>
                                <td><input type="text" class="form-control form-control-sm val-rcpt" value="${i.receipt}"></td>
                                <td><input type="number" class="form-control form-control-sm val-amt" value="${i.amount}"></td>
                                <td><input type="text" class="form-control form-control-sm val-card" value="${i.cardName}"></td>
                                <td><input type="text" class="form-control form-control-sm val-refby" value="${i.refBy}"></td>
                                <td class="small text-danger">${i.error || '<span class="text-success">Ready</span>'}</td>
                            </tr>`;
                        });
                        $('#previewTable tbody').html(html);
                        $('#bulkTotal').text(res.totalAmount);
                        $('#previewModal').modal('show');
                    }
                });
            });

            // AJAX Save Bulk Data
            $('#btnSaveBulk').click(function () {
                var list = [];
                $('#previewTable tbody tr').each(function () {
                    list.push({
                        Name: $(this).find('.val-name').val(),
                        Mobile: $(this).find('.val-mobile').val(),
                        Dob: $(this).find('.val-dob').val(),
                        Gender: $(this).find('.val-sex').val(),
                        Age: $(this).find('.val-age').val(),
                        Spouse: $(this).find('.val-spouse').val(),
                        Email: $(this).find('.val-email').val(),
                        Address: $(this).find('.val-address').val(),
                        City: $(this).find('.val-city').val(),
                        State: $(this).find('.val-state').val(),
                        Pincode: $(this).find('.val-pin').val(),
                        Uhid: $(this).find('.val-uhid').val(),
                        Receipt: $(this).find('.val-rcpt').val(),
                        Amount: $(this).find('.val-amt').val(),
                        CardName: $(this).find('.val-card').val(),
                        RefBy: $(this).find('.val-refby').val()
                    });
                });

                $(this).prop('disabled', true).text("Processing...");

                $.ajax({
                    url: '?handler=UploadEdited',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(list),
                    headers: { "RequestVerificationToken": $('input[name="__RequestVerificationToken"]').val() },
                    success: function (res) {
                        alert("Successfully uploaded " + res.success + " records.");
                        location.href = './Index';
                    }
                });
            });
        });
    </script>
}