@page
@model PLCARD.Pages.Admin.ALLUserModel
@{
    ViewData["Title"] = "User Management";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-primary"><i class="fa fa-users-gear me-2"></i>User Management</h2>
            <p class="text-muted">View and manage all registered system users and their assigned roles.</p>
        </div>
        <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-primary">
            <i class="fa fa-user-plus me-1"></i> Create New User
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Username / Email</th>
                        <th>Roles</th>
                        <th>User ID</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.UsersList)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold">@user.Username</div>
                                <small class="text-muted">@user.Email</small>
                            </td>
                            <td>
                                @foreach (var role in user.Roles)
                                {
                                    <span class="badge @(role == "Admin" ? "bg-danger" : "bg-info") me-1">
                                        @role
                                    </span>
                                }
                            </td>
                            <td>
                                <code class="small text-muted">@user.Id</code>
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group btn-group-sm">
                                    <a class="btn btn-outline-secondary" title="Edit User">
                                        <i class="fa fa-user-pen"></i>
                                    </a>
                                    @if (user.Username != User.Identity?.Name)
                                    {
                                        <button class="btn btn-outline-danger" title="Delete User">
                                            <i class="fa fa-trash-can"></i>
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>