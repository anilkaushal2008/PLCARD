<div class="container-fluid mt-4 px-lg-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-0">
                <i class="fa fa-users-gear me-2 text-primary"></i>User Management
            </h2>
            <p class="text-muted small mb-0">Indus Healthcare | Manage system access and staff roles</p>
        </div>
        <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm">
            <i class="fa fa-user-plus me-1"></i> Create New User
        </a>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm rounded-3 py-3 mb-4">
            <i class="fa fa-check-circle me-2"></i> @TempData["Message"]
        </div>
    }

    <div class="modern-table-container">
        <table class="table table-modern mb-0">
            <thead>
                <tr>
                    <th class="ps-4">User Details</th>
                    <th>Security Roles</th>
                    <th>Status</th>
                    <th class="text-end pe-4">Control Panel</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model.UsersList)
                {
                    <tr class="@(!user.IsActive ? "row-deactivated" : "")">
                        <td class="ps-4">
                            <div class="fw-bold @(user.IsActive ? "text-dark" : "text-muted")">@user.Username</div>
                            <small class="text-muted">@user.Email</small>
                        </td>
                        <td>
                            @foreach (var role in user.Roles)
                            {
                                <span class="badge role-badge @(role == "Admin" ? "bg-danger text-white" : "bg-primary text-white") me-1">
                                    @role
                                </span>
                            }
                        </td>
                        <td>
                            @if (user.IsActive)
                            {
                                <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-3 py-2 rounded-pill">
                                    <i class="fa fa-circle-check me-1"></i> ACTIVE
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25 px-3 py-2 rounded-pill">
                                    <i class="fa fa-circle-xmark me-1"></i> INACTIVE
                                </span>
                            }
                        </td>
                        <td class="text-end pe-4">
                            <div class="d-flex justify-content-end gap-2">
                                <a asp-page="/Admin/EditUser" asp-route-id="@user.Id" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                    <i class="fa fa-user-pen"></i>
                                </a>

                                @if (user.Username != User.Identity?.Name)
                                {
                                    <form method="post" asp-page-handler="ToggleStatus" asp-route-id="@user.Id">
                                        <button type="submit" class="btn btn-sm @(user.IsActive ? "btn-outline-warning" : "btn-outline-success") rounded-pill px-3" style="min-width: 120px;">
                                            @if (user.IsActive)
                                            {
                                                <span><i class="fa fa-ban me-1"></i> Deactivate</span>
                                            }
                                            else
                                            {
                                                <span><i class="fa fa-check me-1"></i> Activate</span>
                                            }
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>