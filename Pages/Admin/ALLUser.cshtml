@page
@model PLCARD.Pages.Admin.ALLUserModel
@{
    ViewData["Title"] = "User Management";
}

<style>
    /* Premium Table Card with Extra Deep Shadow & Bottom Margin */
    .modern-table-container {
        background: #fff;
        border-radius: 20px;
        overflow: hidden;
        margin-top: 25px;
        
        /* Triple-Layered Shadow for "Stunning" Depth */
        box-shadow:
            0 20px 25px -5px rgba(0, 0, 0, 0.08),
            0 10px 10px -5px rgba(0, 0, 0, 0.04),
            0 40px 60px -15px rgba(0, 0, 0, 0.1) !important;
        
        /* Added Bottom Margin here */
        margin-bottom: 80px;
        border: 1px solid rgba(0,0,0,0.03);
    }

    .table-modern thead th {
        background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%);
        color: #fff;
        font-size: 0.75rem;
        text-transform: uppercase;
        padding: 20px 25px;
        border: none;
        letter-spacing: 0.8px;
    }
    
    .table-modern td {
        padding: 18px 25px;
        vertical-align: middle;
        border-bottom: 1px solid #f1f5f9;
    }

    .table-modern tr:last-child td { border-bottom: none; }

    .role-badge {
        font-weight: 700;
        font-size: 0.65rem;
        padding: 5px 12px;
        border-radius: 50px;
        text-transform: uppercase;
    }

    .row-deactivated { background-color: #fafbfc; opacity: 0.8; }
</style>
