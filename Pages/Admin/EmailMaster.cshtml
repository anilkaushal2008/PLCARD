@page
@model PLCARD.Pages.Admin.EmailMasterModel
@{
    ViewData["Title"] = "Email Master";
}

<style>
    /* Premium Dashboard Styles */
    .dashboard-title { letter-spacing: -0.5px; color: #1e293b; }

    .modern-table-container {
        background: #fff;
        border-radius: 20px;
        overflow: hidden;
        margin-top: 20px;
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.08), 0 10px 10px -5px rgba(0, 0, 0, 0.04), 0 40px 60px -15px rgba(0, 0, 0, 0.1) !important;
        margin-bottom: 70px;
        border: 1px solid rgba(0,0,0,0.03);
    }

    .table-modern thead th {
        background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%);
        color: #fff;
        font-size: 0.75rem;
        text-transform: uppercase;
        padding: 20px 25px;
        border: none;
        letter-spacing: 0.8px;
    }
    
    .table-modern td { padding: 18px 25px; vertical-align: middle; border-bottom: 1px solid #f1f5f9; }
    .table-modern tr:last-child td { border-bottom: none; }

    /* Modal Styling */
    .modal-content { border-radius: 24px; border: none; box-shadow: 0 25px 70px rgba(0,0,0,0.3); }
    .modal-header { background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%); color: white; border-radius: 24px 24px 0 0; padding: 25px 35px; }
    
    .form-control { border-radius: 10px; border: 1.5px solid #e2e8f0; padding: 12px 15px; }
</style>

<div class="container-fluid mt-4 px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold dashboard-title mb-0">Email Recipient Master</h2>
            <p class="text-muted small mb-0">Indus Healthcare Group: Notification Management</p>
        </div>
        <button type="button" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm" onclick="openEmailModal(0)">
            <i class="fa fa-plus-circle me-1"></i> Add Recipient
        </button>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm rounded-3 py-3">
            <i class="fa fa-circle-check me-2"></i> @TempData["Message"]
        </div>
    }

    <div class="modern-table-container">
        <table class="table table-modern align-middle mb-0">
            <thead>
                <tr>
                    <th class="ps-4">Recipient Identity</th>
                    <th>Email Address</th>
                    <th>Status</th>
                    <th class="text-end pe-4">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.EmailRecipients != null && Model.EmailRecipients.Any())
                {
                    foreach (var item in Model.EmailRecipients)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold text-dark">@item.RecipientName</div>
                                <small class="text-muted">ID: #@item.Id</small>
                            </td>
                            <td>
                                <span class="text-primary fw-medium"><i class="fa fa-envelope me-2 opacity-50"></i>@item.EmailAddress</span>
                            </td>
                            <td>
                                @if (item.IsActive == true)
                                {
                                    <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill px-3">ACTIVE</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 rounded-pill px-3">INACTIVE</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <button class="btn btn-sm btn-outline-primary rounded-pill px-3" onclick="openEmailModal(@item.Id)">
                                    <i class="fa fa-edit me-1"></i> Edit
                                </button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center py-5 text-muted">
                            <i class="fa fa-users-slash fa-2x mb-3 d-block opacity-25"></i>
                            No recipients defined in the PLCARD master list.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="emailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold" id="modalTitle">Recipient Configuration</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-page-handler="Save">
                <div class="modal-body p-4 p-md-5">
                    <input type="hidden" asp-for="Recipient.Id" id="field_Id" />
                    
                    <div class="row g-4">
                        <div class="col-12">
                            <label class="form-label fw-bold small text-uppercase text-muted">Full Name</label>
                            <input asp-for="Recipient.RecipientName" id="field_Name" class="form-control" placeholder="e.g. Anil Kaushal" required />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-bold small text-uppercase text-muted">Email Address</label>
                            <input asp-for="Recipient.EmailAddress" id="field_Email" type="email" class="form-control" placeholder="user@indushospitals.com" required />
                        </div>
                        <div class="col-12">
                            <div class="form-check form-switch p-3 bg-light rounded-3 border mt-2">
                                <input class="form-check-input ms-0 me-3" type="checkbox" id="field_IsActive" name="Recipient.IsActive" value="true">
                                <input type="hidden" name="Recipient.IsActive" value="false" />
                                <label class="form-check-label fw-bold text-dark mb-0" for="field_IsActive">Authorized for Notifications</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 pb-4 pe-5">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-5 shadow fw-bold">Save Recipient</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openEmailModal(id) {
            if (id === 0) {
                $('#modalTitle').text('Add New Recipient');
                $('#field_Id').val(0);
                $('#field_Name').val('');
                $('#field_Email').val('');
                $('#field_IsActive').prop('checked', true);
                $('#emailModal').modal('show');
            } else {
                $.get('?handler=FetchRecipient&id=' + id, function (data) {
                    $('#modalTitle').text('Edit Recipient: ' + data.recipientName);
                    $('#field_Id').val(data.id);
                    $('#field_Name').val(data.recipientName);
                    $('#field_Email').val(data.emailAddress);
                    
                    // Handle nullable boolean correctly in JS
                    var activeValue = data.isActive === true;
                    $('#field_IsActive').prop('checked', activeValue);
                    
                    $('#emailModal').modal('show');
                });
            }
        }
    </script>
}