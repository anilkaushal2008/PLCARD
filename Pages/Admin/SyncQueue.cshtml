@page
@model PLCARD.Pages.Admin.SyncQueueModel
@{
    ViewData["Title"] = "Sync Queue Monitor";
}

<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">

<style>
    /* 1. Dashboard Layout & Typography */
    .dashboard-title { letter-spacing: -0.5px; color: #1e293b; }

    /* 2. Premium Card with Extra Deep Static Shadows (No Hover) */
    .modern-table-container { 
        background: #ffffff; 
        border-radius: 20px; 
        overflow: hidden;
        margin-top: 20px;
        /* Triple-Layered "Floating" Shadow - Fixed (No Hover) */
        box-shadow: 0 25px 30px -5px rgba(0, 0, 0, 0.08), 0 10px 10px -5px rgba(0, 0, 0, 0.04), 0 40px 60px -15px rgba(0, 0, 0, 0.1) !important;
        border: 1px solid rgba(0,0,0,0.03);
        padding: 25px;
    }

    /* 3. Table Styling with Gradient Header */
    .table-modern thead th { 
        background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%) !important; 
        color: #fff !important; 
        font-size: 0.75rem; 
        text-transform: uppercase; 
        padding: 20px 15px !important; 
        border: none !important; 
        letter-spacing: 0.8px; 
    }
    
    .table-modern td { 
        padding: 18px 15px; 
        vertical-align: middle; 
        border-bottom: 1px solid #f1f5f9; 
    }

    /* Removing Hover Effect specifically */
    .table-modern.table-hover tbody tr:hover {
        background-color: transparent !important;
        color: inherit !important;
    }

    /* 4. DataTables UI Customization */
    .dataTables_wrapper .dataTables_filter input {
        border-radius: 10px;
        padding: 8px 15px;
        border: 1.5px solid #e2e8f0;
        margin-left: 10px;
        width: 280px;
        font-size: 0.9rem;
    }
    .dataTables_wrapper .dataTables_paginate .paginate_button.current {
        background: #0d6efd !important;
        color: white !important;
        border-radius: 10px;
        border: none;
    }

    /* 5. Status Badges */
    .status-badge { font-size: 0.65rem; font-weight: 800; padding: 6px 14px; border-radius: 30px; text-transform: uppercase; display: inline-flex; align-items: center; gap: 5px; }
    .bg-pending { background: #fff7ed; color: #9a3412; border: 1px solid #ffedd5; }
    .bg-failed { background: #fef2f2; color: #991b1b; border: 1px solid #fee2e2; }
    .bg-success-light { background: #f0fdf4; color: #166534; border: 1px solid #dcfce7; }
    
    .module-badge { background-color: #334155; color: #ffffff; font-weight: 700; padding: 4px 10px; border-radius: 6px; font-size: 0.65rem; letter-spacing: 0.5px; }
    .retry-count { font-family: 'JetBrains Mono', monospace; font-weight: bold; font-size: 0.85rem; }
</style>

<div class="container-fluid mt-4 px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold dashboard-title mb-0">Replication Queue</h2>
            <p class="text-muted small mb-0">Monitoring data sync across <span class="text-primary fw-bold">Indus Healthcare</span> hubs</p>
        </div>
        <div class="d-flex gap-2">
            <form method="post" asp-page-handler="RetryFailed">
                <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm">
                    <i class="fas fa-redo-alt me-1 text-white-50"></i> Retry Failed
                </button>
            </form>
            <form method="post" asp-page-handler="ClearProcessed">
                <button type="submit" class="btn btn-outline-secondary rounded-pill px-4 fw-bold">
                    <i class="fas fa-trash-alt me-1"></i> Clear History
                </button>
            </form>
        </div>
    </div>

    <div class="modern-table-container mb-5">
        <div class="table-responsive">
            <table class="table table-modern align-middle mb-0" id="syncTable">
                <thead>
                    <tr>
                        <th class="ps-3">Target Hub</th>
                        <th>Module</th>
                        <th>Record ID</th>
                        <th class="text-center">Retries</th>
                        <th>Status</th>
                        <th>Added On</th>
                        <th class="pe-3">Audit Log</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.SyncQueue)
                    {
                        <tr>
                           <td class="ps-3">
                                <div class="fw-bold text-dark">@(item.IntServer?.VchServerName ?? "Unknown Hub")</div>
                                <div class="text-muted" style="font-size: 0.7rem;">
                                    <i class="fa fa-location-dot me-1 text-danger opacity-75"></i>@(item.IntServer?.VchLocation ?? "Global")
                                </div>
                            </td>
                            <td>
                                <span class="module-badge">@item.VchModule</span>
                            </td>
                            <td class="fw-bold text-primary font-monospace">#@item.IntRecordId</td>
                            <td class="text-center">
                                <span class="retry-count @(item.IntRetryCount >= 4 ? "text-danger" : "text-muted")">
                                    @item.IntRetryCount <small class="opacity-50">/ 5</small>
                                </span>
                            </td>
                            <td>
                                @if (item.BitProcessed == true) {
                                    <span class="status-badge bg-success-light"><i class="fas fa-check-circle"></i> Synced</span>
                                } else if (item.IntRetryCount >= 5) {
                                    <span class="status-badge bg-failed"><i class="fas fa-exclamation-triangle"></i> Failed</span>
                                } else {
                                    <span class="status-badge bg-pending"><i class="fas fa-clock"></i> Pending</span>
                                }
                            </td>
                            <td data-order="@(item.DtAdded?.Ticks ?? 0)">
                                <div class="fw-bold small text-dark">@item.DtAdded?.ToString("dd MMM")</div>
                                <div class="text-muted" style="font-size: 0.7rem;">@item.DtAdded?.ToString("HH:mm tt")</div>
                            </td>
                            <td class="pe-3">
                                @if (item.BitProcessed == true) 
                                {
                                    <span class="text-success small fw-medium"><i class="fa fa-check-double me-1 opacity-50"></i> Replicated</span> 
                                }
                                else if (!string.IsNullOrEmpty(item.VchErrorLog))
                                {
                                    <div class="text-danger small font-monospace" title="@item.VchErrorLog" style="max-width: 220px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; background: #fff5f5; padding: 4px 8px; border-radius: 5px;">
                                        @item.VchErrorLog
                                    </div>
                                }
                                else 
                                {
                                    <span class="text-muted small italic">In Queue...</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.0.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

    <script>
        $(document).ready(function () {
            $('#syncTable').DataTable({
                "pageLength": 10,
                "ordering": true,
                "order": [[5, "desc"]], 
                "language": {
                    "search": "",
                    "searchPlaceholder": "Filter logs...",
                    "paginate": {
                        "next": '<i class="fas fa-chevron-right small"></i>',
                        "previous": '<i class="fas fa-chevron-left small"></i>'
                    }
                },
                "columnDefs": [
                    { "orderable": false, "targets": [6] }
                ]
            });
        });
    </script>
}