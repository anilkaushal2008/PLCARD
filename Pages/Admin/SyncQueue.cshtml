@page
@model PLCARD.Pages.Admin.SyncQueueModel
@{
    ViewData["Title"] = "Sync Queue Monitor";
}

<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
    .queue-card { 
        border-radius: 20px; 
        background: #ffffff; 
        border: 1px solid #f1f5f9; 
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04); 
    }
    .dashboard-title { color: #1e293b; font-size: 1.75rem; }
    
    /* DataTables UI Overrides */
    .dataTables_wrapper .dataTables_filter input {
        border-radius: 20px;
        padding: 8px 15px;
        border: 1px solid #e2e8f0;
        margin-left: 10px;
        width: 250px;
    }
    .dataTables_wrapper .dataTables_paginate .paginate_button.current {
        background: #0d6efd !important;
        color: white !important;
        border-radius: 8px;
        border: none;
    }
    .table thead th { background-color: #f8fafc; color: #64748b; font-size: 0.75rem; text-transform: uppercase; font-weight: 700; border-bottom: 2px solid #edf2f7; }
    
    /* Status Badges */
    .status-badge { font-size: 0.7rem; font-weight: 800; padding: 6px 14px; border-radius: 30px; text-transform: uppercase; display: inline-flex; align-items: center; gap: 5px; }
    .bg-pending { background: #fff7ed; color: #9a3412; border: 1px solid #ffedd5; }
    .bg-failed { background: #fef2f2; color: #991b1b; border: 1px solid #fee2e2; }
    .bg-success-light { background: #f0fdf4; color: #166534; border: 1px solid #dcfce7; }
    
    .module-badge { background-color: #334155; color: #ffffff; font-weight: 700; padding: 4px 10px; border-radius: 6px; font-size: 0.7rem; }
    .retry-count { font-family: 'Courier New', Courier, monospace; font-weight: bold; }
</style>

<div class="container-fluid mt-4 px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold dashboard-title mb-0">Replication Queue</h1>
            <p class="text-muted mb-0">Monitoring data sync across <strong>Indus Healthcare</strong> hubs</p>
        </div>
        <div class="d-flex gap-2">
            <form method="post" asp-page-handler="RetryFailed">
                <button type="submit" class="btn btn-warning rounded-pill px-4 fw-bold shadow-sm">
                    <i class="fas fa-redo-alt me-1"></i> Retry Failed
                </button>
            </form>
            <form method="post" asp-page-handler="ClearProcessed">
                <button type="submit" class="btn btn-outline-secondary rounded-pill px-4 fw-bold">
                    <i class="fas fa-trash-alt me-1"></i> Clear History
                </button>
            </form>
        </div>
    </div>

    <div class="card queue-card p-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="syncTable">
                <thead>
                    <tr>
                        <th>Target Hub</th>
                        <th>Module</th>
                        <th>Record ID</th>
                        <th class="text-center">Retries</th>
                        <th>Status</th>
                        <th>Added On</th>
                        <th>Last Log / Error</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.SyncQueue)
                    {
                        <tr>
                           <td>
    @* Added ?. to ensure it doesn't crash if IntServer is null *@
    <div class="fw-bold text-dark">@(item.IntServer?.VchServerName ?? "Unknown Hub")</div>
    <div class="text-muted small">
        <i class="fa fa-map-marker-alt me-1"></i>@(item.IntServer?.VchLocation ?? "N/A")
    </div>
</td>
                            <td>
                                <span class="module-badge">@item.VchModule</span>
                            </td>
                            <td class="fw-bold text-primary">#@item.IntRecordId</td>
                            <td class="text-center">
                                <span class="retry-count @(item.IntRetryCount >= 4 ? "text-danger" : "text-muted")">
                                    @item.IntRetryCount / 5
                                </span>
                            </td>
                            <td>
                                @if (item.BitProcessed == true) {
                                    <span class="status-badge bg-success-light"><i class="fas fa-check-circle"></i> Synced</span>
                                } else if (item.IntRetryCount >= 5) {
                                    <span class="status-badge bg-failed"><i class="fas fa-exclamation-triangle"></i> Failed</span>
                                } else {
                                    <span class="status-badge bg-pending"><i class="fas fa-clock"></i> Pending</span>
                                }
                            </td>
                            <td data-order="@(item.DtAdded?.Ticks ?? 0)">
                                <small class="text-muted fw-bold">@item.DtAdded?.ToString("dd MMM, HH:mm")</small>
                            </td>
                            <td>
                                @if (item.BitProcessed == true) 
                                {
                                    <span class="text-success small"><i class="fa fa-check me-1"></i> Data Replicated Successfully</span> 
                                }
                                else if (!string.IsNullOrEmpty(item.VchErrorLog))
                                {
                                    <div class="text-danger small" title="@item.VchErrorLog" style="max-width: 250px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                        <i class="fa fa-bug me-1"></i> @item.VchErrorLog
                                    </div>
                                }
                                else 
                                {
                                    <span class="text-muted small">Waiting in queue...</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.0.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

    <script>
        $(document).ready(function () {
            $('#syncTable').DataTable({
                "pageLength": 10,
                "ordering": true,
                "order": [[5, "desc"]], // Sort by Added On descending
                "language": {
                    "search": "",
                    "searchPlaceholder": "Search server, module or ID...",
                    "paginate": {
                        "next": '<i class="fas fa-chevron-right"></i>',
                        "previous": '<i class="fas fa-chevron-left"></i>'
                    }
                },
                "columnDefs": [
                    { "orderable": false, "targets": [6] } // Disable sorting for Error Log
                ]
            });
        });
    </script>
}