@page
@model PLCARD.Pages.Admin.SyncCenterModel
@{
    ViewData["Title"] = "Node Intelligence";
}

<style>
    /* 1. Base UI */
    body { background: #f1f5f9; font-family: 'Inter', system-ui, sans-serif; overflow-x: hidden; }
    .dashboard-wrapper { width: 100%; padding: 30px 50px; margin-bottom: 100px; }

    /* 2. Header & Clock Badge */
    .heartbeat-icon { color: #ef4444; animation: heart-pulse 1.2s infinite; font-size: 1.1rem; }
    @@keyframes heart-pulse { 0% { transform: scale(1); } 14% { transform: scale(1.2); } 28% { transform: scale(1); } }
    
    .live-pulse-dot { width: 10px; height: 10px; background: #f43f5e; border-radius: 50%; display: inline-block; animation: pulse-red 2s infinite; margin-right: 8px; }
    @@keyframes pulse-red { 0% { box-shadow: 0 0 0 0 rgba(244, 63, 94, 0.7); } 70% { box-shadow: 0 0 0 10px rgba(244, 63, 94, 0); } 100% { box-shadow: 0 0 0 0 rgba(244, 63, 94, 0); } }

    /* 3. Compact Stat Cards (Reduced Height) */
    .stat-card-premium {
        border-radius: 16px;
        padding: 15px 20px;
        color: white;
        height: 95px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        position: relative;
        overflow: hidden;
        box-shadow: 0 8px 20px rgba(0,0,0,0.08);
    }
    .bg-gradient-indigo { background: linear-gradient(135deg, #1e1b4b 0%, #4338ca 100%); }
    .bg-gradient-emerald { background: linear-gradient(135deg, #064e3b 0%, #10b981 100%); }
    .bg-gradient-rose { background: linear-gradient(135deg, #881337 0%, #f43f5e 100%); }

    .stat-label { font-size: 0.65rem; font-weight: 800; text-transform: uppercase; letter-spacing: 1.2px; opacity: 0.8; margin-bottom: 2px; }
    .stat-value { font-size: 2.2rem; font-weight: 900; line-height: 1; }

    /* 4. Telemetry Rows (Horizontal Flow) */
    .node-row { 
        background: #ffffff; 
        border-radius: 15px; 
        padding: 18px 30px; 
        margin-bottom: 12px; 
        display: flex; 
        align-items: center; 
        border: 1px solid #e2e8f0; 
        transition: all 0.2s ease;
    }
    .node-row:hover { border-color: #3b82f6; box-shadow: 0 10px 25px rgba(0,0,0,0.04); }

    /* 5. Audit Data Columns */
    .telemetry-unit { border-left: 1px solid #f1f5f9; padding-left: 25px; text-align: center; }
    .data-header { font-size: 0.6rem; font-weight: 800; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.8px; margin-bottom: 4px; }
    .data-audit-value { font-family: 'JetBrains Mono', monospace; font-size: 1.1rem; font-weight: 700; color: #1e293b; }
    .audit-separator { color: #cbd5e1; margin: 0 8px; font-weight: 300; }
    
    .sync-critical { color: #ef4444 !important; font-weight: 900; }
    .status-badge { padding: 6px 14px; border-radius: 50px; font-size: 0.7rem; font-weight: 800; display: inline-flex; align-items: center; gap: 6px; }
    .online { background: #dcfce7; color: #15803d; border: 1px solid #bbf7d0; }
    .offline { background: #fee2e2; color: #b91c1c; border: 1px solid #fecaca; }

    .pulse-text { font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; color: #64748b; background: #f8fafc; padding: 4px 10px; border-radius: 8px; }
</style>

<div class="dashboard-wrapper">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <div class="d-flex align-items-center mb-1">
                <span class="live-pulse-dot"></span>
                <span class="fw-bold text-danger text-uppercase" style="font-size: 0.7rem; letter-spacing: 1.5px;">Network Activity Live</span>
            </div>
            <h1 style="font-weight: 900; letter-spacing: -1.5px; font-size: 2.6rem; color: #0f172a; margin: 0;">Node Intelligence</h1>
        </div>

        <div class="text-end">
            <div class="bg-white border rounded-3 p-2 px-3 shadow-sm d-flex align-items-center gap-3">
                <i class="fa fa-heartbeat heartbeat-icon"></i>
                <div style="border-left: 1px solid #eee; padding-left: 15px;">
                    <div class="text-muted fw-bold text-uppercase" style="font-size: 0.55rem; letter-spacing: 1px;"></div>
                    <div class="h4 mb-0 fw-black font-monospace text-dark" id="liveClock">@DateTime.Now.ToString("HH:mm:ss")</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-5">
        <div class="col-md-4">
            <div class="stat-card-premium bg-gradient-indigo">
                <div class="stat-label">Infrastructure Nodes</div>
                <div class="stat-value">@Model.ServerStatuses.Count</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card-premium bg-gradient-emerald">
                <div class="stat-label">Healthy Connection</div>
                <div class="stat-value">@Model.OnlineCount</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card-premium bg-gradient-rose">
                <div class="stat-label">Critical Alerts</div>
                <div class="stat-value">@(Model.ServerStatuses.Count - Model.OnlineCount)</div>
            </div>
        </div>
    </div>

    <div class="d-none d-lg-flex px-5 py-2 text-muted fw-bold small text-uppercase" style="font-size: 0.6rem; letter-spacing: 1.5px;">
        <div style="flex: 2.5;">Hospital Unit Hub</div>
        <div style="flex: 1.2;" class="text-center">Connection</div>
        <div style="flex: 2;" class="text-center">Card Audit (HQ/Hub)</div>
        <div style="flex: 2;" class="text-center">Corp Audit (HQ/Hub)</div>
        <div style="flex: 1;" class="text-center">Latency</div>
        <div style="flex: 1.2;" class="text-end">Controls</div>
    </div>

    <div class="node-list">
        @foreach (var server in Model.ServerStatuses)
        {
            <div class="node-row">
                <div style="flex: 2.5;" class="d-flex align-items-center">
                    <div class="bg-primary bg-opacity-10 p-3 rounded-3 me-3 text-primary shadow-sm">
                        <i class="fa fa-h-square h4 mb-0"></i>
                    </div>
                    <div>
                        <div class="fw-bold text-dark h5 mb-0" style="letter-spacing: -0.5px;">@server.ServerName</div>
                        <small class="text-muted fw-medium"><i class="fa fa-map-marker-alt text-danger me-1 small"></i> @server.Location</small>
                    </div>
                </div>

                <div style="flex: 1.2;" class="text-center">
                    @if (server.IsOnline) {
                        <span class="status-badge online">● CONNECTED</span>
                    } else {
                        <span class="status-badge offline">○ OFFLINE</span>
                    }
                </div>

                <div class="telemetry-unit" style="flex: 2;">
                    <div class="data-header">HQ / Hub Cards</div>
                    <div class="data-audit-value">
                        <span>@server.CentralCardCount</span>
                        <span class="audit-separator">/</span>
                        <span class="@(server.IsOnline && server.CentralCardCount != server.HubCardCount ? "sync-critical" : "")">
                            @server.HubCardCount
                        </span>
                    </div>
                </div>

                <div class="telemetry-unit" style="flex: 2;">
                    <div class="data-header">HQ / Hub Corps</div>
                    <div class="data-audit-value">
                        <span>@server.CentralCompanyCount</span>
                        <span class="audit-separator">/</span>
                        <span class="@(server.IsOnline && server.CentralCompanyCount != server.HubCompanyCount ? "sync-critical" : "")">
                            @server.HubCompanyCount
                        </span>
                    </div>
                </div>

                <div class="telemetry-unit" style="flex: 1;">
                    <div class="data-header">Pulse</div>
                    <div class="mt-1">
                        @if (server.IsOnline) {
                            <span class="pulse-text">@server.LatencyMs ms</span>
                        } else {
                            <span class="text-muted small">---</span>
                        }
                    </div>
                </div>

                <div style="flex: 1.2;" class="text-end">
                    <button class="btn btn-sm btn-dark rounded-pill px-4 fw-bold shadow-sm" onclick="location.reload()">
                        <i class="fa fa-rotate"></i>
                    </button>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function updateClock() {
            const now = new Date();
            const timeString = String(now.getHours()).padStart(2, '0') + ":" + 
                             String(now.getMinutes()).padStart(2, '0') + ":" + 
                             String(now.getSeconds()).padStart(2, '0');
            $('#liveClock').text(timeString);
        }
        setInterval(updateClock, 1000);
        setInterval(() => { location.reload(); }, 60000); // Auto-refresh every minute
    </script>
}