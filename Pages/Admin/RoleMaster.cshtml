@page
@model PLCARD.Pages.Admin.RoleMasterModel
@{
    ViewData["Title"] = "Role Master";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-4">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white fw-bold">
                    <i class="fa fa-plus-circle me-2"></i>Create New Role
                </div>
                <div class="card-body">
                    <form method="post" asp-page-handler="Create">
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Role Name</label>
                            <input asp-for="NewRoleName" class="form-control" placeholder="e.g. Accountant" required />
                        </div>
                        <button type="submit" class="btn btn-primary w-100">Add Role</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white fw-bold text-primary d-flex justify-content-between align-items-center">
                    <span><i class="fa fa-shield-halved me-2"></i>Existing System Roles</span>
                    <span class="badge bg-light text-dark border">Total: @Model.Roles.Count</span>
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-4">Role Name</th>
                                <th>Role ID</th>
                                <th class="text-end pe-4">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var role in Model.Roles)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold">@role.Name</td>
                                    <td><code class="small text-muted">@role.Id</code></td>
                                    <td class="text-end pe-4">
                                        @if (role.Name != "Admin")
                                        {
                                            <form method="post" asp-page-handler="Delete" asp-route-id="@role.Id" onsubmit="return confirm('Delete this role?');">
                                                <button class="btn btn-sm btn-outline-danger"><i class="fa fa-trash"></i></button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>