@page
@model PLCARD.Pages.Admin.ServerRegistryModel
@{
    ViewData["Title"] = "Hub Management";
}

<style>
    /* 1. Dashboard Layout & Typography */
    .dashboard-title {
        letter-spacing: -0.5px;
        color: #1e293b;
    }

    /* 2. Premium Table Card with Extra Deep Static Shadows */
    .modern-table-container {
        background: #fff;
        border-radius: 20px;
        overflow: hidden;
        margin-top: 20px;
        /* Triple-Layered "Floating" Shadow - Fixed (No Hover) */
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.08), 0 10px 10px -5px rgba(0, 0, 0, 0.04), 0 40px 60px -15px rgba(0, 0, 0, 0.1) !important;
        margin-bottom: 70px;
        border: 1px solid rgba(0,0,0,0.03);
    }

    /* 3. Table Styling */
    .table-modern thead th {
        background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%);
        color: #fff;
        font-size: 0.75rem;
        text-transform: uppercase;
        padding: 20px 25px;
        border: none;
        letter-spacing: 0.8px;
    }
    
    .table-modern td {
        padding: 18px 25px;
        vertical-align: middle;
        border-bottom: 1px solid #f1f5f9;
    }

    .table-modern tr:last-child td {
        border-bottom: none;
    }

    /* 4. Modal Design */
    .modal-content {
        border-radius: 24px;
        border: none;
        box-shadow: 0 25px 70px rgba(0,0,0,0.3);
    }
    
    .modal-header {
        background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%);
        color: white;
        border-radius: 24px 24px 0 0;
        padding: 25px 35px;
    }

    /* 5. Form & Elements */
    .form-label {
        font-weight: 800;
        font-size: 0.7rem;
        text-transform: uppercase;
        color: #64748b;
        margin-bottom: 8px;
        letter-spacing: 0.5px;
    }

    .form-control {
        border-radius: 10px;
        border: 1.5px solid #e2e8f0;
        padding: 12px 15px;
        font-size: 0.95rem;
    }

        .form-control:focus {
            border-color: #0d6efd;
            box-shadow: 0 0 0 4px rgba(13, 110, 253, 0.1);
        }

    .service-section-header {
        font-size: 0.85rem;
        letter-spacing: 1px;
        border-left: 5px solid #0d6efd;
        padding-left: 12px;
        margin-top: 20px;
    }

    .input-group-text {
        border-radius: 10px 0 0 10px;
        border: 1.5px solid #e2e8f0;
        border-right: none;
    }

    .input-group .form-control {
        border-radius: 0 10px 10px 0;
    }

    .badge.rounded-pill {
        font-weight: 700;
        letter-spacing: 0.5px;
        font-size: 0.65rem;
    }
</style>

<div class="container-fluid mt-4 px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold dashboard-title mb-0">Hub Management</h2>
            <p class="text-muted small mb-0">Indus Healthcare Group: Global Synchronization Network</p>
        </div>
        <button type="button" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm" onclick="openRegistryModal(0)">
            <i class="fa fa-plus-circle me-1"></i> Register New Hub
        </button>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm rounded-3 py-3">
            <i class="fa fa-circle-check me-2"></i> @TempData["Message"]
        </div>
    }

    <div class="modern-table-container mb-5">
        <table class="table table-modern align-middle mb-0">
            <thead>
                <tr>
                    <th class="ps-4">Hospital Hub</th>
                    <th>Location</th>
                    <th>Created On</th>
                    <th>Status</th>
                    <th class="text-end pe-4">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.ServerRegistries != null && Model.ServerRegistries.Any())
                {
                    foreach (var item in Model.ServerRegistries)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold text-dark">@item.VchServerName</div>
                                <small class="text-muted">ID: #@item.IntServerId</small>
                            </td>
                            <td><i class="fa fa-location-dot text-danger me-1 small"></i> @item.VchLocation</td>
                            <td><small>@(item.DtCreated?.ToString("dd-MMM-yyyy") ?? "N/A")</small></td>
                            <td>
                                @if (item.BitIsActive == true)
                                {
                                    <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-3 rounded-pill">ACTIVE</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 px-3 rounded-pill">INACTIVE</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <button class="btn btn-sm btn-outline-primary rounded-pill px-3" onclick="openRegistryModal(@item.IntServerId)">
                                    <i class="fa fa-edit me-1"></i> Configure
                                </button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center py-5 text-muted">No hubs registered yet. Start by clicking "Register New Hub".</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="registryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold" id="modalTitle">Register Hub</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-page-handler="Save" id="registryForm">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4 p-md-5">
                    <input type="hidden" asp-for="ServerEntry.IntServerId" id="field_Id" />

                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="form-label">Hospital Name</label>
                            <input asp-for="ServerEntry.VchServerName" id="field_Name" class="form-control" placeholder="e.g. Indus Jaipur" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Location</label>
                            <input asp-for="ServerEntry.VchLocation" id="field_Location" class="form-control" placeholder="e.g. Rajasthan" required />
                        </div>

                        <div class="col-12 mt-5">
                            <h6 class="text-primary fw-bold service-section-header text-uppercase">
                                <i class="fa fa-link me-2"></i> API Service Endpoints
                            </h6>
                            <p class="text-muted small mb-3">Define the specific URLs for this branch based on Master Service Types.</p>
                        </div>

                        @if (Model.ActiveServices != null && Model.ActiveServices.Any())
                        {
                            @foreach (var service in Model.ActiveServices)
                            {
                                <div class="col-12 mb-2">
                                    <label class="form-label d-flex justify-content-between">
                                        <span>@service.ServiceName</span>
                                        <span class="text-info lowercase fw-normal">Method: @service.DefaultMethod</span>
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light border-end-0 text-primary"><i class="fa fa-globe"></i></span>
                                        <input type="url" 
                                               name="ServiceURL_@service.ServiceTypeId" 
                                               id="endpoint_@service.ServiceTypeId" 
                                               class="form-control font-monospace dynamic-endpoint-input" 
                                               placeholder="https://hub-api-url.com/service-path" />
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="col-12">
                                <div class="alert alert-info py-2 small">
                                    <i class="fa fa-info-circle me-2"></i> Please define services in <strong>Service Type Master</strong> first.
                                </div>
                            </div>
                        }

                        <div class="col-12">
                            <div class="form-check form-switch p-3 bg-light rounded-3 border mt-3">
                                <input class="form-check-input ms-0 me-3 shadow-none" type="checkbox" id="field_IsActive" name="ServerEntry.BitIsActive" value="true" checked>
                                <input type="hidden" name="ServerEntry.BitIsActive" value="false" />
                                <label class="form-check-label fw-bold text-dark mb-0" for="field_IsActive">
                                    Hub Connection Status: <span id="statusLabel" class="text-primary">Active</span>
                                </label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 pb-4 pe-5">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-5 shadow fw-bold">
                        <i class="fa fa-save me-1"></i> Save Hub Configuration
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
    function openRegistryModal(id) {
        // Reset
        $('#registryForm')[0].reset();
        $('.dynamic-endpoint-input').val(''); 

        if (id === 0) {
            $('#modalTitle').text('Register New Hospital Hub');
            $('#field_Id').val(0);
            $('#field_IsActive').prop('checked', true);
            updateStatusLabel(true);
            $('#registryModal').modal('show');
        } else {
            // Fetch Hub Main Info
            $.get('?handler=FetchServer&id=' + id, function (data) {
                $('#modalTitle').text('Update Hub: ' + data.vchServerName);
                $('#field_Id').val(data.intServerId || data.serverId);
                $('#field_Name').val(data.vchServerName);
                $('#field_Location').val(data.vchLocation);
                
                var isActive = data.bitIsActive || data.isActive;
                $('#field_IsActive').prop('checked', isActive);
                updateStatusLabel(isActive);

                // Fetch Linked Endpoints (The Dynamic URLs)
                $.get('?handler=FetchEndpoints&hubId=' + id, function (endpoints) {
                    if (endpoints && endpoints.length > 0) {
                        endpoints.forEach(function (e) {
                            $('#endpoint_' + e.serviceTypeId).val(e.url);
                        });
                    }
                    $('#registryModal').modal('show');
                });
            });
        }
    }

    function updateStatusLabel(isChecked) {
        $('#statusLabel').text(isChecked ? "Active" : "Inactive");
        $('#statusLabel').toggleClass('text-primary', isChecked).toggleClass('text-danger', !isChecked);
    }

    $('#field_IsActive').change(function() {
        updateStatusLabel($(this).is(':checked'));
    });
    </script>
}