@page
@model PLCARD.Pages.Admin.ServerRegistryModel
@{
    ViewData["Title"] = "Hub Management";
}

<style>
    /* Premium Dashboard UI */
    .modern-table-container { background: #fff; border-radius: 16px; overflow: hidden; box-shadow: 0 15px 35px rgba(0,0,0,0.1); margin-top: 20px; }
    .table-modern thead th { background-color: #0d6efd; color: #fff; font-size: 0.75rem; text-transform: uppercase; padding: 18px 25px; border: none; letter-spacing: 0.5px; }
    .table-modern td { padding: 15px 25px; vertical-align: middle; }
    
    /* Modal Customization */
    .modal-content { border-radius: 20px; border: none; box-shadow: 0 25px 50px rgba(0,0,0,0.2); }
    .modal-header { background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%); color: white; border-radius: 20px 20px 0 0; padding: 20px 30px; }
    .form-label { font-weight: 700; font-size: 0.7rem; text-transform: uppercase; color: #64748b; margin-bottom: 6px; }
    .form-control { border-radius: 8px; border: 1.5px solid #e2e8f0; padding: 10px; }
    .form-control:focus { border-color: #0d6efd; box-shadow: 0 0 0 3px rgba(13, 110, 253, 0.1); }
</style>

<div class="container-fluid mt-4 px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold dashboard-title mb-0">Hub Management</h2>
            <p class="text-muted-small mb-0">Indus Healthcare Group: Global Synchronization Network</p>
        </div>
        <button type="button" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm" onclick="openRegistryModal(0)">
            <i class="fa fa-plus-circle me-1"></i> Register New Hub
        </button>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm rounded-3 py-3">
            <i class="fa fa-circle-check me-2"></i> @TempData["Message"]
        </div>
    }

    <div class="modern-table-container">
        <table class="table table-modern align-middle mb-0">
            <thead>
                <tr>
                    <th class="ps-4">Hospital Hub</th>
                    <th>Location</th>
                    <th>Sync Path</th>
                    <th>Status</th>
                    <th class="text-end pe-4">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.ServerRegistries)
                {
                    <tr>
                        <td class="ps-4">
                            <div class="fw-bold text-dark">@item.VchServerName</div>
                            <small class="text-muted">ID: #@item.IntServerId</small>
                        </td>
                        <td><i class="fa fa-location-dot text-danger me-1 small"></i> @item.VchLocation</td>
                        <td><code class="small text-muted">@item.VchApiUrl</code></td>
                        <td>
                            @if (item.BitIsActive == true) {
                                <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-3 rounded-pill">ACTIVE</span>
                            } else {
                                <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 px-3 rounded-pill">INACTIVE</span>
                            }
                        </td>
                        <td class="text-end pe-4">
                            <button class="btn btn-sm btn-outline-primary rounded-pill px-3" onclick="openRegistryModal(@item.IntServerId)">
                                <i class="fa fa-edit me-1"></i> Edit
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="registryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-bold" id="modalTitle">Register Hub</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-page-handler="Save" id="registryForm">
                <div class="modal-body p-4 p-md-5">
                    @* Hidden ID field determines if we Add (0) or Edit (>0) *@
                    <input type="hidden" asp-for="ServerEntry.IntServerId" id="field_Id" />

                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="form-label">Hospital Name</label>
                            <input asp-for="ServerEntry.VchServerName" id="field_Name" class="form-control" placeholder="e.g. Indus Jaipur" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Location</label>
                            <input asp-for="ServerEntry.VchLocation" id="field_Location" class="form-control" placeholder="e.g. Rajasthan" required />
                        </div>
                        <div class="col-12">
                            <label class="form-label text-primary">Master Data Sync URL (POST)</label>
                            <input asp-for="ServerEntry.VchApiUrl" id="field_SyncUrl" class="form-control font-monospace" required />
                        </div>
                        <div class="col-12">
                            <label class="form-label text-success">Health URL (GET)</label>
                            @* Fixed ID for JS mapping *@
                            <input asp-for="ServerEntry.VchApihealth" id="healthurlid" class="form-control font-monospace" required />
                        </div>
                        <div class="col-12">
                            <div class="form-check form-switch p-3 bg-light rounded-3 border">
                                <input class="form-check-input ms-0 me-3" type="checkbox" id="field_IsActive" name="ServerEntry.BitIsActive" value="true">
                                <input type="hidden" name="ServerEntry.BitIsActive" value="false" />
                                <label class="form-check-label fw-bold text-dark mb-0" for="field_IsActive">
                                    Hub Status: <span id="statusLabel" class="text-primary">Active</span>
                                </label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-5 shadow fw-bold">
                        <i class="fa fa-save me-1"></i> Save Hub
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
    function openRegistryModal(id) {
        // Reset the form to clear previous data/validation
        $('#registryForm')[0].reset();

        if (id === 0) {
            // --- ADD MODE ---
            $('#modalTitle').text('Register New Hospital Hub');
            $('#field_Id').val(0);
            $('#field_IsActive').prop('checked', true);
            $('#statusLabel').text("Active").addClass('text-primary').removeClass('text-danger');
            $('#registryModal').modal('show');
        } else {
            // --- EDIT MODE (AJAX) ---
            $.get('?handler=FetchServer&id=' + id, function (data) {
                console.log("Server Data Received:", data); 

                $('#modalTitle').text('Update Hub: ' + data.vchServerName);
                
                // Set Values
                $('#field_Id').val(data.intServerId || data.serverId);
                $('#field_Name').val(data.vchServerName);
                $('#field_Location').val(data.vchLocation || data.location);
                $('#field_SyncUrl').val(data.vchApiUrl);
                
                // Bulletproof Health URL mapping (handles h vs H)
                var healthVal = data.vchApihealth || data.vchApiHealth || data.apiHealth || "";
                $('#healthurlid').val(healthVal); 
                
                // Handle Checkbox & Label
                var isActive = data.bitIsActive || data.isActive;
                $('#field_IsActive').prop('checked', isActive);
                $('#statusLabel').text(isActive ? "Active" : "Inactive");
                $('#statusLabel').toggleClass('text-primary', isActive).toggleClass('text-danger', !isActive);
                
                $('#registryModal').modal('show');
            });
        }
    }

    // Dynamic Label update for the switch
    $('#field_IsActive').change(function() {
        var isChecked = $(this).is(':checked');
        $('#statusLabel').text(isChecked ? "Active" : "Inactive");
        $('#statusLabel').toggleClass('text-primary', isChecked).toggleClass('text-danger', !isChecked);
    });
    </script>
}