@page "{id}"
@model PLCARD.Pages.Admin.EditUserModel
@{
    ViewData["Title"] = "Update User Permissions";
}

<style>
    .edit-card {
        background: #fff;
        border-radius: 24px;
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.08), 0 40px 60px -15px rgba(0, 0, 0, 0.1) !important;
        border: 1px solid rgba(0,0,0,0.03);
    }
    .role-selection-box {
        background: #f8fafc;
        border-radius: 15px;
        padding: 20px;
        border: 1px solid #e2e8f0;
    }
    .form-check-input:checked { background-color: #0d6efd; border-color: #0d6efd; }
    .form-label-header { font-weight: 800; font-size: 0.75rem; text-transform: uppercase; color: #64748b; letter-spacing: 1px; }
</style>

<div class="container-fluid mt-5 px-lg-5">
    <div class="row justify-content-center">
        <div class="col-xl-6 col-lg-8">
            
            <div class="d-flex align-items-center mb-4">
                <a asp-page="/Admin/ALLUser" class="btn btn-light rounded-circle me-3 shadow-sm">
                    <i class="fa fa-arrow-left"></i>
                </a>
                <h3 class="fw-bold mb-0">User Account Settings</h3>
            </div>

            <div class="edit-card p-4 p-md-5">
                <form method="post">
                    <input type="hidden" asp-for="UserId" />
                    <input type="hidden" asp-for="Username" />

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-4">
                                <label class="form-label-header d-block mb-2">Username</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0"><i class="fa fa-user-circle text-muted"></i></span>
                                    <input class="form-control bg-light border-0 fw-bold" value="@Model.Username" readonly />
                                </div>
                            </div>

                            <div class="mb-4">
                                <label class="form-label-header d-block mb-2">Reset Password</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white border-end-0 text-primary"><i class="fa fa-key"></i></span>
                                    <input asp-for="NewPassword" type="password" class="form-control border-start-0" placeholder="New password (optional)" />
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label-header d-block mb-2">Assigned Roles</label>
                            <div class="role-selection-box">
                                @foreach (var role in Model.AllRoles)
                                {
                                    <div class="form-check mb-2">
                                        <input class="form-check-input" type="checkbox" name="SelectedRoles" value="@role" id="role_@role" 
                                               @(Model.SelectedRoles.Contains(role) ? "checked" : "")>
                                        <label class="form-check-label fw-600 text-dark ps-2" for="role_@role">
                                            @role
                                        </label>
                                    </div>
                                }
                            </div>
                            <small class="text-muted mt-2 d-block">Check the boxes to grant permissions.</small>
                        </div>
                    </div>

                    <hr class="my-5 opacity-5">

                    <div class="d-flex justify-content-end gap-3">
                        <a asp-page="/Admin/ALLUser" class="btn btn-light rounded-pill px-4">Cancel</a>
                        <button type="submit" class="btn btn-primary rounded-pill px-5 fw-bold shadow">
                            <i class="fa fa-save me-2"></i> Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>