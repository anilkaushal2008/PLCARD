@page
@model PLCARD.Pages.Reports.MonthlyModel
@{
    ViewData["Title"] = "Performance Report";
}

<div class="container mt-4">
    <div class="row align-items-center mb-4">
        <div class="col-md-5">
            <h3><i class="fa fa-chart-line text-primary me-2"></i> Performance Analysis</h3>
        </div>
        
        <div class="col-md-7">
            <form method="get" class="row g-2 justify-content-end">
                <div class="col-auto">
                    <label class="small fw-bold text-muted">From</label>
                    <input type="date" asp-for="FromDate" class="form-control form-control-sm" />
                </div>
                <div class="col-auto">
                    <label class="small fw-bold text-muted">To</label>
                    <input type="date" asp-for="ToDate" class="form-control form-control-sm" />
                </div>
                <div class="col-auto align-self-end">
                    <button type="submit" class="btn btn-sm btn-primary px-3">
                        <i class="fa fa-filter me-1"></i> Apply Filter
                    </button>
                </div>
            </form>
        </div>
    </div>

    @if (Model.Data.Count == 0)
    {
        <div class="alert alert-info border-0 shadow-sm">
            <i class="fa fa-info-circle me-2"></i> No cards were issued during this period.
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-md-6 mb-4">
                <div class="card shadow border-0">
                    <div class="card-header bg-white fw-bold">Distribution</div>
                    <div class="card-body">
                        <canvas id="typeChart" style="max-height: 300px;"></canvas>
                    </div>
                </div>
            </div>
            <div class="col-md-6 mb-4">
                <div class="card shadow border-0">
                    <div class="card-header bg-white fw-bold">Volume</div>
                    <div class="card-body">
                        <canvas id="volumeChart" style="max-height: 300px;"></canvas>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const labels = @Html.Raw(Json.Serialize(Model.Labels));
        const chartData = @Html.Raw(Json.Serialize(Model.Data));

        if (labels.length > 0) {
        new Chart(document.getElementById('typeChart'), {
        type: 'doughnut',
        data: {
        labels: labels,
        datasets: [{
        data: chartData,
        backgroundColor: ['#FFD700', '#C0C0C0', '#E5E4E2', '#36A2EB']
        }]
        }
        });

        new Chart(document.getElementById('volumeChart'), {
        type: 'bar',
        data: {
        labels: labels,
        datasets: [{
        label: 'Total Issued',
        data: chartData,
        backgroundColor: '#0d6efd',
        borderRadius: 5
        }]
        },
        options: {
        scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }
        }
        });
        }
    </script>
}
